{game_entity
	(include "/properties/car.ext")
	(include "/properties/selection/vehicle_elongated.inc" scale(1.15))
	{props "turret" "with_gun" "open_top" "flak" "multi_board" "truck" "vision_lev02" "tractor" "tractor_heavy" "detect_cannon_aa"}
	{able "emit_on_attack"}
	{extension "volvo_127d_itk40.mdl"}
	{collider "truck"}
	{patherId "blitz36"}
	{extension "crew.ext"}
	{targetSelector "tank_zenite"}

	("wheel" args "wheelright1")
	("wheel" args "wheelleft1")
	("wheel" args "wheelright2")
	("wheel" args "wheelleft2")

	("glass" args "glass1")
	("glass" args "glass2")
	("glass" args "glass3")
	("glass" args "glass4")
	("fuel" args "fuel")
	("transmission" args "transmission")
	
	("bodyback" repair(30))
	("gun" repair(30) thickness(15))
	("turret" repair(45))
	{volume "body1" {able {holed}}}
	{volume "fuel" {able {NoWoundDecal 0}}}
	{volume "transmission" {able {NoWoundDecal 0}}}
	{volume "turret1" {thickness 6}}
	{volume "turret2" {thickness 6}}
	{volume "turret3" {thickness 6}}
	{volume "turret4" {thickness 6} {able {holed}}}
	{volume "turret5" {thickness 6}}

	("wood" args "bodyback1")
	("wood" args "bodyback2")
	("wood" args "bodyback3")
	("wood" args "bodyback4")
	("wood" args "bodyback5")

	{extender "inventory"
		{box
			{weight 2400}
			{item "bulletfin_20_auto ap" 160}		; 10 clips (2x 20 rounds each)
			{item "bulletfin_20_auto he" 240}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{weapon "20mm_itk40" filling "bulletfin_20_auto he" 40}
			{Barrels 2}
			{charger "charger"}
			("abm_dymamic_aaa"
				zeroing(1.2)
				dispersion(0.15)
			)
		}
	}

	{mass 5044} ;// 4392kg + 652kg itk40
	{Chassis
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03d") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_car"
			speed(60) ;----------------------------------Max speed. ?
			speedatmaxturn(15) ;-------------------------Max speed at max turn.
			reverse(32) ;--------------------------------Max speed in Reverse. ?
			weight(5.0) ;--------------------------------Weight in Tonnes.
			power(88) ;----------------------------------Horse Power.
			fuel(75) ;-----------------------------------Fuel capacity in Litres. ?
			type(fuel) ;---------------------------------Fuel type.
			range(230) ;---------------------------------Range in Kilometers. ?
		)
	}
	{bone "gun_rot"
		{limits -10 88}
		{speed2 60}
	}
	{bone "turret"
		{speed2 60}
	}
}
