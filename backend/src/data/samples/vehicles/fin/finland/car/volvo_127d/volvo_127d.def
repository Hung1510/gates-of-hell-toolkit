{game_entity
	(include "/properties/car.ext")
	(include "/properties/selection/vehicle_elongated.inc" scale(1.15))
	{props "multi_board" "truck" "vision_lev02" "tractor" "tractor_heavy" "Captor"}
	{able "emit_on_attack"}
	{extension "volvo_127d.mdl"}
	{collider "truck"}
	{patherId "blitz36"}

	("wheel" args "wheelright1")
	("wheel" args "wheelleft1")
	("wheel" args "wheelright2")
	("wheel" args "wheelleft2")

	("glass" args "glass1")
	("glass" args "glass2")
	("glass" args "glass3")
	("glass" args "glass4")
	("fuel" args "fuel")
	("transmission" args "transmission")
	
	("bodyback" repair(30))
	{volume "body1" {able {holed}}}
	{volume "fuel" {able {NoWoundDecal 0}}}
	{volume "transmission" {able {NoWoundDecal 0}}}

	("wood" args "bodyback1")
	("wood" args "bodyback2")
	("wood" args "bodyback3")
	("wood" args "bodyback4")
	("wood" args "bodyback5")

	("crew_2_human")

	("board_animation"
		place(driver)
		board_begin(board_big-midcar_driver)
		board_end(pose_seat_volvo_lv127d_driver)
		base(doorleft)
	)
	("board_animation"
		place(commander)
		board_begin(board_big-midcar)
		board_end(pose_seat_volvo_lv127d_commander)
		base(doorright)
	)

	{boarder
		{anm "passenger"
			{forward	{begin "board_body"} {end "pose_seat_volvo_lv127d_passenger1"} {base "board"}}
			{reverse	{end "emit_body" 1} {base "board"}}
		}
		{anm "passenger1"
			{forward	{begin "board_body"} {end "pose_seat_volvo_lv127d_passenger2"} {base "board"}}
			{reverse	{end "emit_body" 1} {base "board"}}
		}
		{anm "passenger2"
			{forward	{begin "board_body"} {end "pose_seat_volvo_lv127d_passenger3"} {base "board"}}
			{reverse	{end "emit_body" 1} {base "board"}}
		}
		{anm "passenger3"
			{forward {begin "board_body"} {end "pose_seat_volvo_lv127d_passenger4"} {base "board"}}
			{reverse	{end "emit_body" 1} {base "board"}}
		}
	}

	("passenger_human" place(seat1)		bone(seat1)		door(emit4)	animation(passenger3) group(passenger))
	("passenger_human" place(seat2)		bone(seat2)		door(emit3)	animation(passenger)  group(passenger))
	("passenger_human" place(seat3)		bone(seat3)		door(emit4)	animation(passenger2) group(passenger))
	("passenger_human" place(seat4)		bone(seat4)		door(emit3)	animation(passenger1) group(passenger))
	("passenger_human" place(seat5)		bone(seat5)		door(emit4)	animation(passenger1) group(passenger))
	("passenger_human" place(seat6)		bone(seat6)		door(emit3)	animation(passenger3) group(passenger))
	("passenger_human" place(seat7)		bone(seat7)		door(emit4)	animation(passenger2) group(passenger))
	("passenger_human" place(seat8)		bone(seat8)		door(emit3)	animation(passenger1) group(passenger))
	("passenger_human" place(seat9)		bone(seat9)		door(emit4)	animation(passenger)  group(passenger))
	("passenger_human" place(seat10)	bone(seat10)	door(emit3)	animation(passenger)  group(passenger))
	("passenger_human" place(seat11)	bone(seat11)	door(emit4)	animation(passenger3) group(passenger))
	("passenger_human" place(seat12)	bone(seat12)	door(emit3)	animation(passenger2) group(passenger))

	{extender "inventory"
		{box
		}
	}

	{mass 4392}
	{Chassis
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03d") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_car"
			speed(60) ;----------------------------------Max speed. ?
			speedatmaxturn(15) ;-------------------------Max speed at max turn.
			reverse(32) ;--------------------------------Max speed in Reverse. ?
			weight(4.4) ;--------------------------------Weight in Tonnes.
			power(88) ;----------------------------------Horse Power.
			fuel(75) ;-----------------------------------Fuel capacity in Litres. ?
			type(fuel) ;---------------------------------Fuel type.
			range(230) ;---------------------------------Range in Kilometers. ?
		)
	}
}
