{game_entity
	(include "/properties/car.ext")
	(include "/properties/selection/vehicle_elongated.inc" scale(0.85))
	{props "multi_board" "truck" "vision_lev02" "tractor" "tractor_heavy" "Captor"}
	{able "emit_on_attack"}
	{extension "latil_m2tl6.mdl"}
	{collider "truck"}
	{patherId "maultier"}

	("wheel" args "wheelright1")
	("wheel" args "wheelleft1")
	("wheel" args "wheelright2")
	("wheel" args "wheelleft2")

	("glass" args "glass1")
	("glass" args "glass2")
	("glass" args "glass3")
	("fuel" args "fuel")
	("transmission" args "transmission")

	("bodyback" repair(30))

	("shield_cover")

	{volume "body1" {able {holed}}}
	{volume "bodyback1" {able {holed}}}
	{volume "bodyback2" {able {holed}}}
	{volume "bodyback3" {able {holed}}}
	{volume "shield_cover" {able {holed}}}
	{volume "fuel" {able {NoWoundDecal 0}}}

	("crew_2_human")

	("board_animation"
		place(driver)
		board_begin(board_SdKfz251-1)
		board_end(pose_latil_m2tl6_driver)
		base(doorright)
	)
	("board_animation"
		place(commander)
		board_begin(board_SdKfz251-1)
		board_end(pose_latil_m2tl6_commander)
		base(doorleft)
	)

	{boarder
		{anm "passenger1"
			{forward {begin "board_body"} {end "pose_latil_m2tl6_passenger_00"} {base "board"}}
			{reverse {end "emit_body" 1} {base "board"}}
		}
		{anm "passenger2"
			{forward {begin "board_body"} {end "pose_latil_m2tl6_passenger_01"} {base "board"}}
			{reverse {end "emit_body" 1} {base "board"}}
		}
	}

	("crew_human" place(seat1)	bone(seat01)	door(emit3)	animation(passenger1) group(passenger))
	("crew_human" place(seat2)	bone(seat02)	door(emit3)	animation(passenger2) group(passenger))
	("crew_human" place(seat3)	bone(seat03)	door(emit3)	animation(passenger1) group(passenger))
	("crew_human" place(seat4)	bone(seat04)	door(emit3)	animation(passenger2) group(passenger))

	{extender "shield" {on}}

	{extender "inventory"
		{box
		}
	}

	{mass 4000}
	{Chassis
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03d") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_car"
			speed(45) ;----------------------------------Max speed.
			speedatmaxturn(15) ;-------------------------Max speed at max turn.
			reverse(20) ;--------------------------------Max speed in Reverse.
			weight(4.0) ;--------------------------------Weight in Tonnes.
			power(68) ;----------------------------------Horse Power.
			fuel(115) ;----------------------------------Fuel capacity in Litres. 75L + 40L
			type(fuel) ;---------------------------------Fuel type.
			range(290) ;---------------------------------Range in Kilometers.
		)
	}
}