{game_entity
	(include "/properties/cannon_mgun.ext")
	{extension "maxim_m32_33.mdl"}
	{props "vision_lev00_can" "cannon_sandbag_small" "detect_cannon_aa" "c_mg_med"}

	{volume "ammo_box"
		{thickness 2}
		{able {contact 0}}
	}
	{volume "water_can"
		{thickness 2}
		{able {contact 0}}
	}

	{boarder
		{anm "gunner"
			{forward {end "pose_maxim_gunner" 10}}
		}
		{anm "commander"
			{forward {end "pose_maxim_commander" 10}}
		}
		{anm "driver2"	;// gunner
			{forward {end "mortar_driver_l" 10}}
		}
		{anm "driver1"	;// commander
			{forward {end "mgun_browning_driver_l" 10}}
		}
	}

	{extender "cannon"
		{animation
			;// "gunner" "commander"
			{move "mgun_browning_driver_l" "mortar_driver_l"}
			{fire "" "mg_maxim_commander_fire"}
			{aim "mg_maxim_gunner_aim" "mg_maxim_commander_aim"}
			{reload "mg_maxim_gunner_reload" "mg_maxim_commander_reload"}
		}
	}

	{extender "inventory"
		{box
			{item "mgun_rus belt ap" 1000}
			{item "sandbag_vehicle" 2}
		}
	}

	{Weaponry
		{place "mgun"
			{type "main"}
			{gunner "gunner"}
			{charger "gunner"}
			{weapon "maxim_m32" filling "mgun_rus belt ap" 250}
			("abm_mgun")
			{Rotate}
			{basic}
		}
	}

	{mass 41.1} ;18.1kg gun and water + 23kg tripod
	{Chassis
		("mobility_cannon"
			speed(12) ;----------------------------------Max speed.
			weight(41.1) ;-------------------------------Weight in Kilograms.
		)
	}

	{bone "basis"
		{speed2 20}
	}
	{bone "gun_rot"
		{limits -15 20}
		{speed2 40}
	}
	{bone "turret"
		{limits -25 25}
		{speed2 40}
	}
}