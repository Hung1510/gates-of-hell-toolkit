{game_entity
	(include "/properties/cannon_mgun.ext")
	{extension "mg08_fin.mdl"}
	{props "vision_lev00_can" "cannon_sandbag_small" "detect_cannon_aa" "c_mg_med"}

	;// Custom Properties (Not on every mg stand)
	{volume "ammo_box" {thickness 2} {able {contact 0}}}
	{volume "water_can" {thickness 2} {able {contact 0}}}
	{volume "body1" {able {holed}}}
	{volume "body11" {able {holed}}}

	{boarder
		{anm "gunner"
			{forward {end "pose_maxim_gunner" 10}}
		}
		{anm "commander"
			{forward {end "pose_maxim_commander" 10}}
		}
		{anm "driver1"	;// gunner
			{forward {end "mortar_driver_l" 10}}
		}
		{anm "driver2"	;// commander
			{forward {end "mgun_browning_driver_l" 10}}
		}
	}

	{extender "cannon"
		{animation
			;// "gunner" "commander"
			{move "mortar_driver_l" "mgun_browning_driver_l"}
			{fire "" "mg_maxim_commander_fire"}
			{aim "mg_maxim_gunner_aim" "mg_maxim_commander_aim"}
			{reload "mg_maxim_gunner_reload" "mg_maxim_commander_reload"}
		}
	}

	{extender "inventory"
		{box
			{item "ammo mgun_ger" 1000}
			{item "sandbag_vehicle" 2}
		}
	}

	{Weaponry
		{place "mgun"
			{type "main"}
			{charger "gunner"}
			{weapon "mg08" filling "ammo mgun_ger" 250}
			("abm_mgun")
			{Rotate}
			{basic}
		}
	}

	{mass 41.1} ;18.1kg gun and water + 23kg tripod
	{Chassis
		("mobility_cannon"
			speed(12) ;----------------------------------Max speed.
			weight(41.1) ;-------------------------------Weight in Kilograms.
		)
	}

	{bone "basis"
		{speed2 20}
	}
	{bone "gun_rot"
		{limits -15 20}
		{speed2 40}
	}
	{bone "turret"
		{limits -15 15}
		{speed2 40}
	}
}