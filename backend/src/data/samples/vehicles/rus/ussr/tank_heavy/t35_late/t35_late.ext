	("shield" args "shieldr" 11)
	("shield" args "shieldl" 11)

	("tracks" repair(40) thickness(20))
	("gun" repair(30) thickness(25))
	("gun1" repair(30) thickness(20))
	("gun2" repair(30) thickness(20))
	("aux_turret" repair(45))

	("fuel" args "fuel1")
	("fuel" args "fuel2")
	("fuel" args "fuel3")
	("ammo" args "ammo1")
	("ammo" args "ammo2")
	("ammo" args "ammo3")
	("ammo" args "ammo4")
	("transmission" args "transmission")

