{game_entity
	(include "/properties/cannon.ext")
	{extension "45mm_21k_naval.mdl"}
	(include "/properties/selection/vehicle.inc" scale(0.7))
	{props "vision_lev03_can" "muzzle_37mm_47mm" "cannon_sandbag_small" "detect_atgun_small" "c_at_med"}

	("gun" repair(30) thickness(25))

	("armor_medium_cannon")
	("crew_wheeled_cannon_3")

	{placer
		{place "driver1" remove}
		{place "driver2" remove}
		{place "driver3" remove}
		{place "seat1" remove}
		{place "seat2" remove}
		{place "seat3" remove}
	}

	{boarder
		{anm "gunner"
			{forward {end "pose_mo4_gunner" 10}}
		}
		{anm "charger"
			{forward {end "pose_mo4_charger" 10}}
		}
		{anm "commander"
			{forward {end "pose_mo4_charger2" 10}}
		}
	}

	{extender "cannon"
		{animation
			{switch "close"}
			;// "gunner" "charger" "commander"
			{move "" "" ""}
			{aim "" "" ""}
			{fire "" "" ""}
			{reload "" "" ""}
		}
		{move {workers clear} {obstacle "close"}}
		{attack {workers "" "" ""} {obstacle "open"}}		;// fire/attack state: cannon aim, fire, and reload events
		{trailing {workers clear}}
		{rotate_ik_Limit 0}
	}

	{extender "inventory"
		{box
			{item "bulletrus_45 he" 30}
			{item "bulletrus_45 aphebc" 30}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{weapon "45mm_21k" filling "bulletrus_45 he" 1}
			{charger "charger"}
			{RestoreIKAfterAim}
			("abm_dymamic_gun_boat"
				zeroing(2.5)
				dispersion(0.20)
			)
		}
	}

	{mass 1500}

	{bone "turret"
		{speed2 20}
	}
	{bone "gun_rot"
		{limits -10 80}
		{speed2 15}
	}
}
