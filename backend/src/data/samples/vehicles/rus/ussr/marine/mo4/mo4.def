{game_entity
	(include "/properties/marine.ext")
	(include "/properties/selection/vehicle_big.inc" scale(1.3))
	{props "marine" "engine" "searchlight" "flag" "vision_lev04_boat" "muzzle_37mm_47mm" "emit_on_sink" "explosion_throw_crew" "boat" "big"}
 	{targetClass "car"}
	{targetSelector "cannon_zenite"}
	{patherID "water"}
	{extension "mo4.mdl"}
	(include "mo4.ext")
	{extension "crew.ext"}

	{extender "enumerator"
		{digit_folder "ru1"}
	}

	{extender "inventory"
		{box
			{Weight 90000}
			{item "bulletrus_45 he" 900}
			{item "bulletrus_45 aphebc" 100}
			{item "ammo hmgun_rus api" 4000}
		}
	}

	{Weaponry
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "45mm_21k" filling "bulletrus_45 he" 1}
			{foresight "foresight1"}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic_gun_boat"
				zeroing(2.5)
				dispersion(0.20)
			)
			{basic}
			{ai_in_manual}
		}
		{place "gun1"
			{RestoreIKAfterAim}
			{weapon "45mm_21k" filling "bulletrus_45 he" 1}
			{foresight "foresight1a"}
			{gunner "gunner2"}
			{charger "charger2"}
			("abm_dymamic_gun_boat"
				zeroing(2.5)
				dispersion(0.20)
			)
			{basic}
			{ai_in_manual}
		}
		{place "mgun1"
			{type "mgun_turret_right"}
			{weapon "dshk" filling "hmgun_rus api" 50}
			{foresight "foresight4"}
			{gunner "gunner3"}
			{charger "gunner3"}
			("abm_mgun_boat")
			{basic}
			{ai_in_manual}
		}
		{place "mgun2"
			{type "mgun_turret_left"}
			{weapon "dshk" filling "hmgun_rus api" 50}
			{foresight "foresight5"}
			{gunner "gunner4"}
			{charger "gunner4"}
			("abm_mgun_boat")
			{basic}
			{ai_in_manual}
		}
		{place "gun2"
			{type "searchlight"}
			{weapon "searchlight"}
			{foresight "foresight6"}
			{gunner "gunner5"}
			{basic}
			{ai_in_manual}
			{rotate}
		}
	}

	{mass 50600}
	{chassis "water"
		("mobility_medium_boat"
			speed(48) ;---------------------------------Max speed.
			speedatmaxturn(20) ;------------------------Max speed at max turn.
			reverse(20) ;-------------------------------Max speed in Reverse.
			weight(50.6) ;------------------------------Weight in Tonnes.
			power(2520) ;-------------------------------Horse Power.
			fuel(6630) ;--------------------------------Fuel capacity in Litres. ;// 5.1 t of fuel @ ~0.7 kg per liter
			type(fuel) ;--------------------------------Fuel type.
			range(547) ;--------------------------------Range in Kilometers. ;// ~340 miles @ 26 knots
		)
		{waterline 0}
	}

	{bone "turret"
		{speed2 20}
	}
	{bone "gun_rot"
		{limits -10 80}
		{speed2 15}
	}
	{bone "aux_turret1"
		{speed2 20}
	}
	{bone "gun_rot1"
		{limits -10 80}
		{speed2 15}
	}
	{bone "gun_2_rot1"
		{speed2 70}
	}
	{bone "gun_2_rot2"
		{limits -12 80}
		{speed2 60}
	}
	{bone "mgun_1_rot1"
		{speed2 70}
	}
	{bone "mgun_1_rot2"
		{limits -10 70}
		{speed2 70}
	}
	{bone "mgun_2_rot1"
		{speed2 70}
	}
	{bone "mgun_2_rot2"
		{limits -10 70}
		{speed2 70}
	}
}
