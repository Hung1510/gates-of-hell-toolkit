{game_entity
	(include "/properties/cannon.ext")
	{extension "20mm_polsten.mdl"}
	(include "/properties/selection/vehicle_small.inc" scale(1.1))
	{props "cannon_small" "automatic" "wheeled" "invisible" "vision_lev02_can" "muzzle_20mm_25mm_auto" "no_sandbags" "trailer" "trailer_light" "detect_cannon_aa" "c_aa_lite"}
	{collider "cannon_small"}
	{targetclass "cannon_zenite"}
	{targetSelector "cannon_zenite"}

	("wheel" args "wheelright")
	("wheel" args "wheelleft")

	("gun" repair(30) thickness(15))

	("armor_light_cannon")
	("crew_wheeled_cannon")

	{volume "body3" {able {holed}}}
	{volume "body7" {tags "invisible"} {able {visible 0}}}
	{volume "magazine" {thickness 2}}
	{volume "wheelleft" {tags "invisible"} {able {visible 0}}}
	{volume "wheelright" {tags "invisible"} {able {visible 0}}}

	{boarder
		{anm "gunner"
			{forward {end "seat_flakvierling_gunner" 10}}
		}
		{anm "commander"
			{forward {end "pose_flak30_loader" 10}}
		}
		{anm "driver1"	;// gunner
			{forward {end "cannon_pak40_pusher_left" 10}}
		}
		{anm "driver2"	;// commander
			{forward {end "cannon_pak40_pusher_right" 10}}
		}
		{anm "seat1"	;// gunner
			{forward {end "seat_flakvierling_gunner" 10}}
		}
		{anm "seat2"	;// commander
			{forward {end "pose_flak30_seatr" 10}}
		}
	}

	{extender "cannon"
		{animation
			{switch "close"}
			;// "gunner" "commander"
			{move "cannon_pak40_pusher_left" "cannon_pak40_pusher_right"}
			{aim "" ""}
			{reload "" "flak30_loader"}
		}
		{move {obstacle "close"}}
		{attack {obstacle "open"}}
		{rotate_ik_Limit 0}
	}

	{extender "inventory"
		{box
			{item "bulleteng_20_auto box ap" 120}		; 12 clips (30 rounds each)
			{item "bulleteng_20_auto box hei" 240}
		}
	}

	{Weaponry
		{place "gun"
			{weapon "20mm_polsten" filling "bulleteng_20_auto box hei" 30}
			{charger "commander"}
			("abm_dymamic_aaa"
				zeroing(1.2)
				dispersion(0.15)
			)
		}
	}

	{mass 218} ;// 161kg base carriage + 57kg polsten
	{Chassis "track"
		("car_trace" fx("tracewheel05a") step(0.14) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("mobility_cannon"
			speed(9.5) ;--------------------------------Max speed.
			weight(218) ;-------------------------------Weight in Kilograms.
		)
	}
	{bone "gun_rot"
		{limits -3 85}
		{speed2 60}
	}
	{bone "turret"
		{speed2 60}
	}
}