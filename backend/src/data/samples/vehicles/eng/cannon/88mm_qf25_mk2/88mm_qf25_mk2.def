{game_entity ;// not in France '40, but used after
	(include "/properties/cannon.ext")
	{extension "88mm_qf25_mk2.mdl"}
	(include "/properties/selection/cannon_elongated.inc" scale(0.95))
	{props "88mm_qf25_mk2" "wheeled" "vision_lev05_can" "muzzle_85mm_93mm" "cannon_sandbag_standard" "trailer" "trailer_medium" "detect_artillery" "indirect_minimap_medium" "c_gun_med"}
	{PatherId "cannon.medium"}
	{targetclass "howitzer"}
	{targetSelector "cannon_howitzer"}

	("wheel" args "wheelright")
	("wheel" args "wheelleft")

	("gun" repair(30) thickness(30))
	("shield" args "shield" 8 "shield")
	("shield" args "upper_shield" 8 "shield")

	("armor_heavy_cannon")
	("crew_wheeled_cannon_4")

	{volume "body1" {able {holed}}}
	{volume "body2" {able {holed}}}
	{volume "shield" {able {holed}}}

	{boarder
		{anm "gunner"
			{forward {end "pose_qf25_gunner" 10}}
		}
		{anm "charger"
			{forward {end "cannon_small_charger" 10}}
		}
		{anm "charger2"
			{forward {end "cannon_small_charger2" 10}}
		}
		{anm "commander"
			{forward {end "cannon_small_commander" 10}}
		}
		{anm "driver1"	;// gunner
			{forward {end "cannon_pak40_pusher_left" 10}}
		}
		{anm "driver2"	;// charger
			{forward {end "cannon_pak40_pusher_right" 10}}
		}
		{anm "driver3"	;// charger2
			{forward {end "mortar_driver_l" 10}}
		}
		{anm "driver4"	;// commander
			{forward {end "mgun_browning_driver_r" 10}}
		}
		{anm "seat1"	;// gunner
			{forward {end "pose_seat_cannon_left" 10}}
		}
		{anm "seat2"	;// charger
			{forward {end "pose_seat_cannon_right" 10}}
		}
		{anm "seat3"	;// charger2
			{forward {end "pose_seat_cannon_right" 10}}
		}
		{anm "seat4"	;// commander
			{forward {end "pose_seat_cannon_left" 10}}
		}
	}

	{extender "cannon"
		{animation
			{switch "close"}
			;// "gunner" "charger" "charger2" "commander"
			{move "cannon_pak40_pusher_left" "cannon_pak40_pusher_right" "mortar_driver_l" "mgun_browning_driver_r" }
			{aim "" "cannon_small_charger_aim" "cannon_small_charger2_aim" "cannon_small_commander_aim"}
			{fire "" "cannon_small_charger_fire" "cannon_small_charger2_fire" "cannon_small_commander_fire"}
			{reload "" "cannon_small_charger_reload" "cannon_small_charger2_reload" "cannon_small_commander_reload"}
		}
		{move {workers "driver1" "driver2" "driver3" "driver4" minWorkers 2} {obstacle "close"}}			;// move state: cannon being pushed and which positions play animations
		{attack {workers "gunner" "charger" "charger2" "commander"} {obstacle "open"}}		;// fire/attack state: cannon aim, fire, and reload events
		{trailing {workers "seat1" "seat2" "seat3" "seat4"}}								;// trailing state: cannon is being towed {obstacle} not needed. Uses "close"
	}

	{extender "inventory"
		{box
			{item "ammo bulleteng_88 he" 25}
			{item "ammo bulleteng_88 ap" 5}
			{item "ammo bulleteng_88 sm" 5}
			{item "sandbag_vehicle" 1}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{weapon "88mm_qf25_mk2" filling "bulleteng_88 he" 1}
			{charger "charger charger2" minWorkers 1}
			{RestoreIKAfterAim}
			("abm_dymamic_gun"
				zeroing(4.0)	; // time it takes to aim until the reticle shrinks. Bigger values, more control.
				dispersion(1)	; // time it takes to distort the reticle when you move the gun (how abrupt it loses zeroing). Bigger values, more control.
			)
		}
	}

	{mass 1633}
	{Chassis "track"
		("car_trace" fx("tracewheel05a") step(0.14) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("mobility_cannon"
			speed(6.2) ;----------------------------------Max speed.
			weight(1633) ;--------------------------------Weight in Kilograms.
		)
	}

	{bone "basis"
		{speed2 10}
	}
	{bone "gun_rot"
		{limits -5 45}
		{speed2 8}
	}
	{bone "turret"
		{limits -4 4}
		{speed2 11}
	}
}
