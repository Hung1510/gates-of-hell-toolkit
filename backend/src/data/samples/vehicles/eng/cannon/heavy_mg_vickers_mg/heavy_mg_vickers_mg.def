{game_entity
	(include "/properties/cannon_mgun.ext")
	{extension "../vickers_mg/vickers_mg.mdl"}
	{props "vickers_mg" "vision_lev00_can" "cannon_sandbag_small_ai" "detect_cannon_aa" "c_mg_med" "no_scavenge"}

	{volume "ammo_box"
		{thickness 2}
		{able {contact 0}}
	}
	{volume "water_can"
		{thickness 2}
		{able {contact 0}}
	}

	{boarder
		{anm "gunner"
			{forward {end "pose_maxim_gunner" 10}}
		}
		{anm "commander"
			{forward {end "pose_maxim_commander" 10}}
		}
		{anm "driver1"
			{forward {end "cannon_maxim_move" 10}}
		}
		{anm "driver2"
			{forward {end "walk_1hand" 10}}
		}
	}

	{extender "cannon"
		{animation
		;// "gunner" "commander"
			{move "mgun_browning_driver_r" "mortar_driver_l"}
			{fire "" "mg_maxim_commander_fire"}
			{aim "mg_maxim_gunner_aim" "mg_maxim_commander_aim"}
			{reload "mg_maxim_gunner_reload" "mg_maxim_commander_reload"}
		}
	}

	{extender "inventory"
		{box
			{item "ammo mgun_eng belt" 1000}
			{item "sandbag_vehicle" 2}
		}
	}

	{Weaponry
		{place "mgun"
			{type "main"}
			{charger "gunner"}
			{weapon "vickers" filling "ammo mgun_eng belt" 250}
			("abm_mgun")
			{Rotate}
			{basic}
		}
	}

	{mass 41.1} ;18.1kg gun and water + 23kg tripod
	{Chassis
		("mobility_cannon"
			speed(12) ;----------------------------------Max speed.
			weight(41.1) ;-------------------------------Weight in Kilograms.
		)
	}

	{bone "basis"
		{speed2 20}
	}
	{bone "gun_rot"
		{limits -30 60}
		{speed2 60}
	}
	{bone "turret"
		{limits -5 5}
		{speed2 40}
	}
}