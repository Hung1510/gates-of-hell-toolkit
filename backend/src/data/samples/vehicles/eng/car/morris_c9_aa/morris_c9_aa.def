{game_entity
	(include "/properties/car.ext")
	(include "/properties/selection/vehicle_elongated.inc" scale(1.0))
	{props "turret" "with_gun" "open_top" "automatic" "truck" "vision_lev02" "muzzle_37mm_40mm_auto" "tractor" "tractor_medium" "detect_cannon_aa"}
	{able "emit_on_attack"}
	{extension "morris_c9_aa.mdl"}
	{extension "crew.ext"}
	{collider "truck"}
	{patherId "blitz36"}
	{targetSelector "cannon_zenite"}


	("wheel" args "wheelright1")
	("wheel" args "wheelleft1")
	("wheel" args "wheelright2")
	("wheel" args "wheelleft2")

	("shield" args "shield1" 5)
	("shield" args "shield2" 5)	

	("glass" args "window1")
	("glass" args "window2")
	("fuel" args "fuel1")
	("fuel" args "fuel2")
	("transmission" args "transmission")

	("gun" repair(30) thickness(20))
	("turret" repair(45))

	{volume "fuel1" {able {NoWoundDecal 0}}}
	{volume "fuel2" {able {NoWoundDecal 0}}}
	{volume "transmission" {able {NoWoundDecal 0}}}
	{volume "engine3" {thickness 1.5}}
	{volume "turret1" {thickness 8}}
	{volume "turret2" {thickness 8}}
	{volume "turret3" {thickness 8}}
	{volume "turret4" {thickness 8}}
	{volume "turret5" {thickness 8}}
	{volume "turret6" {thickness 8}}
	{volume "detail4" {thickness 4}}
	{volume "detail5" {thickness 4}}
	{volume "detail7" {thickness 4}}
	{volume "detail8" {thickness 4}}

	{extender "inventory"
		{box
			{item "bullet_40x331_auto eng apbc" 48}		; 8 boxes of 16 (4x4 rounds each), 128 total
			{item "bullet_40x331_auto eng he" 80}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "40mm_qf_mk6" filling "bullet_40x331_auto eng he" 4}
			("abm_dymamic_aaa"
				zeroing(1.95)
				dispersion(0.24)
			)
		}
	}

	{mass 2900}
	{Chassis
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03d") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_car"
			speed(80) ;----------------------------------Max speed.
			speedatmaxturn(17) ;-------------------------Max speed at max turn.
			reverse(20) ;--------------------------------Max speed in Reverse.
			weight(2.9) ;------------------------------Weight in Tonnes.
			power(70) ;----------------------------------Horse Power.
			fuel(100) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;---------------------------------Fuel type.
			range(257) ;---------------------------------Range in Kilometers.
		)
	}
	{bone "gun_rot"
		{limits -5 88}
		{speed2 60}
	}
	{bone "turret"
		{speed2 60}
	}
}