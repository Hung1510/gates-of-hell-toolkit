{game_entity
	(include "/properties/car.ext")
	(include "/properties/selection/vehicle_elongated.inc" scale(1.0))
	{props "multi_board" "truck" "vision_lev02" "tractor" "tractor_heavy" "Captor"}
	{able "emit_on_attack"}
	{extension "morris_c8.mdl"}
	{collider "truck"}
	{patherId "blitz36"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	("wheel" args "wheelright1")
	("wheel" args "wheelleft1")
	("wheel" args "wheelright2")
	("wheel" args "wheelleft2")

	("glass" args "window1")
	("glass" args "window2")
	("glass" args "window3")
	("glass" args "window4")
	("glass" args "window4")
	("fuel" args "fuel1")
	("fuel" args "fuel2")
	("transmission" args "transmission")

	("bodyback" repair(30))

	{volume "body1" {able {holed}}}
	{volume "body2" {able {holed}}}
	{volume "engine3" {thickness 1.5}}


	("crew_2_human")
;	("passenger_10_human")

	("board_animation"
		place(driver)
		board_begin(board_big-midcar)
		board_end(pose_morrisc8_driver)
		base(doorright)
	)
	("board_animation"
		place(commander)
		board_begin(board_big-midcar_driver)
		board_end(pose_morrisc8_commander)
		base(doorleft)
	)

	{boarder
		{anm "passenger1"
			{forward {begin "board_body"} {end "pose_morrisc8_commander"} {base "doorleft"}}
			{reverse {end "emit_body" 1} {base "doorleft"}}
		}
	}
	{boarder
		{anm "passenger2"
			{forward {begin "board_body"} {end "pose_morrisc8_commander"} {base "doorright"}}
			{reverse {end "emit_body" 1} {base "doorright"}}
		}
	}

	("crew_human" place(seat1)	door(emit2)	bone(seat01) animation(passenger1) group(passenger) off())
	("crew_human" place(seat2)	door(emit2)	bone(seat02) animation(passenger1) group(passenger) off())
	("crew_human" place(seat3)	door(emit1)	bone(seat03) animation(passenger2) group(passenger) off())
	("crew_human" place(seat4)	door(emit1)	bone(seat04) animation(passenger2) group(passenger) off())


	{extender "inventory"
		{box
		}
	}

	{mass 3400}
	{Chassis
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03d") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_car"
			speed(80) ;----------------------------------Max speed.
			speedatmaxturn(15) ;-------------------------Max speed at max turn.
			reverse(22) ;--------------------------------Max speed in Reverse.
			weight(3.4) ;-------------------------------Weight in Tonnes.
			power(70) ;----------------------------------Horse Power.
			fuel(100) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;---------------------------------Fuel type.
			range(257) ;---------------------------------Range in Kilometers.
		)
	}
}


