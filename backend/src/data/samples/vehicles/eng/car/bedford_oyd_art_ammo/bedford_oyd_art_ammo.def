{game_entity
	(include "/properties/car.ext")
	(include "/properties/selection/vehicle_elongated.inc" scale(1.10))
	(include "/properties/resupply.inc")
	{props "truck" "vision_lev02" "tractor" "tractor_heavy" "blast_large"}
	{able "emit_on_attack"}
	{extension "bedford_oyd_art_ammo.mdl"}
	{collider "truck"}
	{patherId "blitz36"}
	


	{extender "enumerator"
		{digit_folder "us2"}
	}

	("wheel" args "wheelright1")
	("wheel" args "wheelleft1")
	("wheel" args "wheelright2")
	("wheel" args "wheelleft2")

	("glass" args "window1")
	("glass" args "window2")
	("glass" args "window3")
	("glass" args "window4")
	("fuel" args "fuel1")
	("fuel" args "fuel2")
	("ammo" args "ammo")
	("transmission" args "transmission")
	
	("bodyback" repair(30))

	{volume "body2" {able {holed}}}
	{volume "bodyback1" {material "wood"} {tags "wood"} {able {holed}}}
	{volume "bodyback2" {material "wood"} {tags "wood"}}
	{volume "bodyback3" {material "wood"} {tags "wood"}}
	{volume "bodyback4" {material "wood"} {tags "wood"}}
	{volume "bodyback5" {material "wood"} {tags "wood"}}
	{volume "bodyback6" {material "wood"} {tags "wood"}}
	{volume "bodyback7" {material "wood"} {tags "wood"}}


	("wood" args "bodyback1")
	("wood" args "bodyback2")
	("wood" args "bodyback3")
	("wood" args "bodyback4")
	("wood" args "bodyback5")
	("wood" args "bodyback6")
	("wood" args "bodyback7")

	("truck_ammo_heavy")
	
	("crew_2_human")

	("board_animation"
		place(driver)
		board_begin(board_big-midcar)
		board_end(seat_driver_car)
		base(doorright)
	)
	("board_animation"
		place(commander)
		board_begin(board_big-midcar_driver)
		board_end(seat_passenger)
		base(doorleft)
	)


	{extender "inventory"
		{box
			{item "repair_kit" 5}
		}
	}

	{mass 6568}
	{Chassis
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03d") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_car"
			speed(65) ;----------------------------------Max speed.
			speedatmaxturn(15) ;-------------------------Max speed at max turn.
			reverse(22) ;--------------------------------Max speed in Reverse.
			weight(6.568) ;-------------------------------Weight in Tonnes. // fully loaded
			power(72) ;----------------------------------Horse Power.
			fuel(145) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;---------------------------------Fuel type.
			range(450) ;---------------------------------Range in Kilometers.
		)
	}
}


