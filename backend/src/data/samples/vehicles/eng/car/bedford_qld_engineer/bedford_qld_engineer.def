{game_entity
	(include "/properties/car.ext")
	
	(include "/properties/selection/vehicle_elongated.inc" scale(1.10))
	(include "/properties/resupply.inc")
	{props "truck" "vision_lev02" "tractor" "tractor_heavy" "blast_large"}
	{able "emit_on_attack"}
	{extension "bedford_qld_engineer.mdl"}
	{collider "truck"}
	{patherId "blitz36"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	("wheel" args "wheelright1")
	("wheel" args "wheelleft1")
	("wheel" args "wheelright2")
	("wheel" args "wheelleft2")

	("glass" args "glass1")
	("glass" args "glass2")
	("glass" args "glass3")
	("glass" args "glass4")
	("fuel" args "fuel1")
	("transmission" args "transmission")

	("bodyback" repair(30))

	("shield_cover")

	{volume "body1" {able {holed}}}
	{volume "bodyback1" {material "wood"} {tags "wood"}}
	{volume "bodyback2" 
		{thickness 4}
	}
	{volume "bodyback3"
		{thickness 4}
	}
	{volume "bodyback4"
		{thickness 4}
	}
	{volume "bodyback5" {material "wood"} {tags "wood"}}
	{volume "bodyback6"
		{thickness 4}
	}
	{volume "transmission" {able {NoWoundDecal 0}}}

	{volume "shield_cover" {able {holed}}}

	("wood" args "bodyback1")
	("wood" args "bodyback5")
	
	("supply_engineer")

	("crew_2_human")


	("board_animation"
		place(driver)
		board_begin(board_SdKfz251-1)
		board_end(pose_qld_driver)
		base(doorright)
	)
	("board_animation"
		place(commander)
		board_begin(board_SdKfz251-1)
		board_end(pose_qld_commander)
		base(doorleft)
	)

	{extender "shield" {on}}

	{extender "inventory"
		{box
			{item "repair_kit" 5}
			{item "at_gs_mk5" "mine" 60}
			{item "mine_detector" 2}
			{item "shovel_eng" 5}
			{item "pickaxe" 5}
			{item "satchel_charge_eng" 5}
			{item "ap_shrapnel_mk1" "mine" 120}
			{item "wirecutters" 2}
		}
	}

	{mass 6985}
	{Chassis
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03d") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_car"
			speed(65) ;----------------------------------Max speed.
			speedatmaxturn(15) ;-------------------------Max speed at max turn.
			reverse(22) ;--------------------------------Max speed in Reverse.
			weight(6.985) ;-------------------------------Weight in Tonnes. //fully loaded
			power(72) ;----------------------------------Horse Power.
			fuel(127) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;---------------------------------Fuel type.
			range(250) ;---------------------------------Range in Kilometers.
		)
	}
}


