{game_entity
	(include "/properties/tank.ext")
	(include "/properties/selection/vehicle_big.inc" scale(0.9))
	{props "heavy" "vision_lev05" "multi_turret" "muzzle_37mm_47mm" "muzzle_75mm_76mm" "smoke" "2in" "detect_tank_heavy"}
	{extension "churchill_mk1.mdl"}
	(include "churchill_mk1.ext")
	{targetclass "tank_heavy"}
	{targetSelector "tank_light"}
	{PatherId "churchill"}
	{collider "tank.heavy"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	("crew_5_human_extended")
	("crew_co_driver" place(gunner3) door(emit3) door2(emit1) door3(emit2))

	{boarder
		{anm "driver"
			{forward {begin "board_t34_driver"} {end "seat_gunner_stand"} {base "open_driver"}}
			{reverse {end "emit_t34_hold"} {base "open_driver"}}
		}
		{anm "co_driver"
			{forward {begin "board_t34_driver"} {end "seat_gunner_stand"} {base "open_gunner3"}}
			{reverse {end "emit_t34_hold"} {base "open_gunner3"}}
		}
		{anm "left"
			{forward {begin "board_Is-2"} {end "seat_commander_hatch"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "right"
			{forward {begin "board_Is-2"} {end "seat_commander_hatch"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "armor1"
			{forward {begin "board_HighArmor"} {end "pose_seat_armor_1"}}
			{reverse {end "emit_tank_2"}}
		}
	}

	("seat_human" place(seat1) bone(seat01) door(emit4) animation(armor1))
	("seat_human" place(seat2) bone(seat02) door(emit5) animation(armor1))
	("seat_human" place(seat3) bone(seat03) door(emit6) animation(armor1))
	("seat_human" place(seat4) bone(seat04) door(emit7) animation(armor1))

	{extender "shield" {on}}

	{extender "smokescreen"
		{cooldown 5}
		{itemTags "mortareng_50 sm"}
	}

	{extender "inventory"
		{box
			{item "bulleteng_40 ap" 149}				;150 rounds
			{item "bulleteng_76_l25 he" 28}				;58 rounds
			{item "bulleteng_76_l25 sm" 29}
			{item "ammo mgun_ger belt mk2" 4725}		;22 belts (225 rounds per belt)
			{item "bren_mk2_drum" filled}
			{item "ammo bren_drum_mag" 503}				;600 rounds
			{item "satchel_charge_eng" 1}
			{item "mortareng_50 sm" 25}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "40mm_qf2_2" filling "bulleteng_40 ap" 1}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic"
				zeroing(2.5)
				dispersion(0.20)
			)
		}
		{place "gun1"
			{RestoreIKAfterAim}
			{weapon "76mm_qf3" filling "bulleteng_76_l25 he" 1}
			{foresight "foresight1a"}
			{gunner "gunner3"}
			{charger "gunner3"}
			("abm_dymamic"
				zeroing(4.0)
				dispersion(0.20)
			)
			{rotate}
			{basic}
			{ai_in_manual}
		}
		{place "mgun2"
			{type "coaxial"}
			{weapon "besa" filling "ammo mgun_ger belt mk2" 225}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "charger"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 38500}
	{Chassis
		("tank_trace" fx("tracks_big") step(0.47) len(0.8))
		("mobility_tank"
			speed(26) ;----------Max speed when fully accelerated on road, km/h.
			reverse(3) ;---------Max speed in reverse on road, km/h.
			traverse(25) ;-------Track traverse, per second, in degrees.
			weight(38.5) ;-------Weight in Tonnes.
			power(350) ;---------Engine Power, in hp.
			track(7.5) ;---------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(681) ;----------Fuel capacity in Litres.
			type(fuel) ;---------Fuel type. (diesel OR fuel)
			range(100) ;---------Range in km, off-road.
		)
	}

	{bone "gun_rot"
		{limits -12.5 20}
		{speed2 8}
	}
	{bone "turret"
		("turret_medium" power_traverse(24))
	}
	{bone "gun1_rot"
		{limits -5 12.5}
		{speed2 3}
	}
	{bone "aux_turret1"
		{limits -12 12}
		{speed2 5}
	}
}