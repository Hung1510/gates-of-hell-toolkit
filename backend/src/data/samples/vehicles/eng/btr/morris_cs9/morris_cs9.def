{game_entity
	(include "/properties/armoredcar.ext")
	(include "/properties/selection/vehicle_elongated.inc" scale(1.0))
	{props "tank" "turret" "wheeled" "explosion_throw_crew" "vision_lev02" "detect_tank_mg"}
	{extension "morris_cs9.mdl"}
	(include "morris_cs9.ext")
	{extension "crew.ext"}
	{targetclass "armoredcar"}
	{targetSelector "tank_bullet"}
	{patherId "sdkfz232"}
	{extender "enumerator"
		{digit_folder "us2"}
	}
	
	{extender "smokescreen"
		{cooldown 5}
		{itemTags "grenade no8_smoke"}
	}

	{extender "inventory"
		{weapon "mgun1" {mask "mountable"}}
		{weapon "mgun2" {mask "mountable"}}
		{box
			{item "bren_mk1" filled {user "mgun1"}}
			{item "boys_mk1" filling "atrifle_eng ap2 ammo" 5 {user "mgun2"}}
			{item "atrifle_eng ap2 ammo" 25}			;// 30 .55 boys rounds
			{item "bren_mag ammo" 972}					;// 1000 rounds
			{item "no8_smoke grenade" 18}				;// 18 4-inch smoke rounds
			;{item "no36m grenade" 6}
		}
	}

	{Weaponry
		{place "mgun1"
			{type "aa"}
			{gunner "gunner"}
			{charger "gunner"}
			{LinkBone "mgun1"}
			{LinkAnimation "off"}
			("abm_mgun")
			{basic}
		}
		{place "mgun2"
			{type "main"}
			{gunner "gunner2"}
			{charger "gunner2"}
			{LinkBone "mgun2"}
			{LinkAnimation "off"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 4500}
	{Chassis "wheel"
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03d") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_btr"
			speed(73) ;----------------------------------Max speed.
			speedatmaxturn(15) ;-------------------------Max speed at max turn.
			reverse(20) ;--------------------------------Max speed in Reverse.
			weight(4.5) ;------------------------------Weight in Tonnes.
			power(96) ;----------------------------------Horse Power.
			fuel(113) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;---------------------------------Fuel type.
			range(385) ;---------------------------------Range in Kilometers.
		)
	}

	{bone "mgun2_h_rot1" ;// Boys turret
		{speed2 60}
	}

	{bone "mgun2_h_rot2"	;// Boys rot
		{speed2 60}
	}


	{bone "mgun1_h_rot1" ;// Bren turret
		{speed2 60}
	}

	{bone "mgun1_h_rot2" ;// Bren rot
		{speed2 60}
	}
	{bone "turret"
		{speed2 20}
	}
}