{game_entity
	(include "/properties/armoredcar.ext")
	(include "/properties/selection/vehicle.inc" scale(0.9))
	{props "tank" "turret" "wheeled" "with_gun" "vision_lev02" "muzzle_37mm_47mm" "smoke" "4in_2x"}
	{extension "humber_mk4.mdl"}
	{extension "crew.ext"}
	(include "humber_mk4.ext")
	{targetclass "armoredcar"}
	{targetSelector "tank_light"}
	{patherId "sdkfz232"}
	
	{sensor
		{visor "main"
			{vision "recon_main"}
		}
	}

	{extender "smokescreen"
		{cooldown 5}
		{itemTags "grenade no8_smoke"}
	}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	{extender "inventory"
		{box
			{item "bulletusa_37 apcbc" 24} 			;51 rounds
			{item "bulletusa_37 he" 26}
			{item "ammo mgun_ger belt mk2" 1800}	;9 belts (2025 rounds)
			{item "satchel_charge_eng" 1}
			{item "bren_mk2_drum" filled}
			{item "ammo bren_drum_mag" 503}				;600 rounds 7.7mm
			{item "no8_smoke grenade" 4}
			;{item "no36m grenade" 6}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "37mm_m6" filling "bulletusa_37 apcbc" 1}
			{gunner "gunner"}
			{charger "commander"}
			("abm_dymamic"
				zeroing(3.0)
				dispersion(0.20)
			)
		}
		{place "mgun2"
			{type "coaxial"}
			{weapon "besa" filling "ammo mgun_ger belt mk2" 225}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "gunner"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 7056}
	{Chassis "wheel"
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_btr"
			speed(80) ;----------------------------------Max speed.
			speedatmaxturn(25) ;-------------------------Max speed at max turn. 
			reverse(21) ;--------------------------------Max speed in Reverse. ;estimated based on gears and max speed
			weight(7.056) ;-------------------------------Weight in Tonnes.
			power(90) ;---------------------------------Horse Power.
			fuel(136) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;-------------------------------Fuel type.
			range(400) ;---------------------------------Range in Kilometers.
		)
	}

	{bone "gun_rot"
		{limits -10 15}
		{speed2 8}
	}
	{bone "turret"
		("turret_light" power_traverse(0)) ;// manual
	}
}
