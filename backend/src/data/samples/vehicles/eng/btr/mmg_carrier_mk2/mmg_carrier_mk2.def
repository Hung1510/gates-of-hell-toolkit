{game_entity
	(include "/properties/tank_unarmed.ext")
	(include "/properties/selection/vehicle.inc" scale(0.9))
	{props "armored_car" "smoke" "4in" "-turret" "mobilegun" "with_gun" "explosion_throw_crew" "vision_lev02" "tractor" "tractor_medium" "detect_tank_mg"}
	{extension "mmg_carrier_mk2.mdl"}
	(include "mmg_carrier_mk2.ext")
	{targetclass "armoredcar" "bullet"}
	{targetSelector "tank_bullet"}
	{patherId "universal"}
	{collider "tank.light"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	{extender "shield" {on}}

	{boarder
		{anm "left"
			{forward {begin "board_tank_left"} {end "pose_univ_carrier_gunner"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "right"
			{forward {begin "board_tank_right"} {end "pose_univ_carrier_driver"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "gunner2"
			{forward {begin "board_tank_right"} {end "pose_univ_carrier_gunner2a"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "armor1"
			{forward {begin "board_tank_left"} {end "pose_univ_carrier_pass_seat01b"}}
			{reverse {end "emit_tank_1"}}
		}
		{anm "armor3"
			{forward {begin "board_tank_left"} {end "pose_univ_carrier_pass_seat03"}}
			{reverse {end "emit_tank_1"}}
		}
		{anm "armor4"
			{forward {begin "board_tank_right"} {end "pose_univ_carrier_pass_seat04"}}
			{reverse {end "emit_tank_1"}}
		}
	}

	("crew_human_visible_anm2" place(driver) door(emit2) door2(emit2) anm_left(right) anm_right(right))
	("crew_human_visible_anm2" place(gunner2) door(emit3) door2(emit4) anm_left(gunner2) anm_right(gunner2))
	("crew_human_visible_anm2" place(gunner) door(emit1) door2(emit2) anm_left(left) anm_right(left))

	("seat_human" place(seat1) bone(seat01) door(emit3) animation(armor1))
	("seat_human" place(seat3) bone(seat03) door(emit5) animation(armor3))
	("seat_human" place(seat4) bone(seat04) door(emit6) animation(armor4))

	{extender "smokescreen"
		{cooldown 5}
		{itemTags "grenade no8_smoke"}
	}
	
	{Placer
		{place "weapon1"
			{entity "lee_enfield_no1_mk3"}
			{Linkbone "weapon1"}
			{handlebone "body"}
		}
		{place "weapon2"
			{entity "lee_enfield_no1_mk3"}
			{Linkbone "weapon2"}
			{handlebone "body"}
		}
	}

	{extender "inventory"
		{weapon "mgun" {mask "mountable"}}
		{box
			;{item "bren_mk2" filled {user "mgun"}} ;// MMG carriers not issued a bren gun
			;{item "bren_mag ammo" 900}
			{item "ammo mgun_eng belt" 4500}		;// 4750 rounds
			{item "no8_smoke grenade" 8}
		}
	}

	{Weaponry
		{place "mgun"
			{type "hull"}
			{LinkBone "mgun"}
			{LinkAnimation "off"}
			{gunner "gunner"}
			{charger "gunner"}
			("abm_mgun")
			{rotate}
			{basic}
		}
		{place "mgun2"
			{type "main"}
			{weapon "vickers" filling "ammo mgun_eng belt" 250}
			{foresight "foresight5"}
			{gunner "gunner2"}
			{charger "gunner2"}
			("abm_mgun")
			{basic}
			{ai_in_manual}
		}
	}

	{mass 3750}
	{Chassis "track"
		("tank_trace" fx("tracks_mid") step(0.32) len(0.5))
		("mobility_tank"
			speed(48) ;----------Max speed when fully accelerated on road, km/h.
			reverse(20) ;--------Max speed in reverse on road, km/h.
			traverse(35) ;-------Track traverse, per second, in degrees.
			weight(3.75) ;-------Weight in Tonnes.
			power(85) ;----------Engine Power, in hp.
			track(5) ;-----------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(91) ;-----------Fuel capacity in Litres.
			type(fuel) ;---------Fuel type. (diesel OR fuel)
			range(150) ;---------Range in km, off-road.
		)
	}
}

