{game_entity
	(include "/properties/armoredcar.ext")
	(include "/properties/selection/vehicle.inc" scale(0.9))
	{props "tank" "turret" "with_gun" "vision_lev02" "muzzle_37mm_47mm" "smoke" "4in_2x"}
	{extension "../daimler_mk2/daimler_mk2_lj.mdl"}
	{extension "../daimler_mk2/crew.ext"}
	(include "../daimler_mk2/daimler_mk2.ext")
	{targetclass "armoredcar"}
	{targetSelector "tank_light"}
	{patherId "sdkfz232"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	{extender "smokescreen"
		{cooldown 5}
		{itemTags "grenade no8_smoke"}
	}

	{extender "inventory"
		{box
			{item "bulleteng_40 littlejohn apcr2" 51}				;52 rounds
			{item "ammo mgun_ger belt mk2" 2475}	;12 belts (2700 rounds)
			{item "satchel_charge_eng" 1}
			{item "bren_mk2_drum" filled}
			{item "ammo bren_drum_mag" 403}				;500 rounds 7.7mm
			{item "no8_smoke grenade" 4}	;In real life, carried 6 extra smokes + 2 preloaded. In-game, each grenade gives 2 shots.
			;{item "no36m grenade" 6}
		}
	}
	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "40mm_qf2_littlejohn" filling "bulleteng_40 littlejohn apcr2" 1}  
			{gunner "gunner"}
			{charger "commander"}
			("abm_dymamic"
				zeroing(3.0)
				dispersion(0.20)
			)
		}
		{place "mgun2"
			{type "coaxial"}
			{weapon "besa" filling "ammo mgun_ger belt mk2" 225}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "commander"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 7600}
	{Chassis "wheel"
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_btr"
			speed(80) ;----------------------------------Max speed.
			speedatmaxturn(25) ;-------------------------Max speed at max turn. 
			reverse(85) ;--------------------------------Max speed in Reverse.
			weight(7.6) ;-------------------------------Weight in Tonnes.
			power(95) ;---------------------------------Horse Power.
			fuel(170) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;-------------------------------Fuel type.
			range(330) ;---------------------------------Range in Kilometers.
		)
	}

	{bone "gun_rot"
		{limits -12 25}
		{speed2 8}
	}
	{bone "turret"
		("turret_light" power_traverse(0)) ;// manual
	}
}
