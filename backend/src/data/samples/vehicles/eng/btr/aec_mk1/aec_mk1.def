{game_entity
	(include "/properties/armoredcar.ext")
	(include "/properties/selection/vehicle.inc" scale(1.0))
	{props "tank" "turret" "wheeled" "with_gun" "vision_lev02" "muzzle_37mm_47mm" "smoke" "2in"}
	{extension "aec_mk1.mdl"}
	{extension "crew.ext"}
	(include "aec_mk1.ext")
	{targetclass "armoredcar"}
	{targetSelector "tank_light"}
	{patherId "sdkfz232"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	{extender "smokescreen"
		{cooldown 5}
		{itemTags "mortareng_50 sm"}
	}

	{extender "inventory"
		{box
			{item "bulleteng_40 ap" 57}				;58 rounds (APHV)
			{item "ammo mgun_ger belt mk2" 2700}	;13 belts (2925 rounds)
			{item "satchel_charge_eng" 1}
			{item "bren_mk2_drum" filled}
			{item "ammo bren_drum_mag" 503}				;600 rounds 7.7mm
			{item "mortareng_50 sm" 18}
			;{item "no36m grenade" 6}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "40mm_qf2_2" filling "bulleteng_40 ap" 1}  
			{gunner "gunner"}
			{charger "commander"}
			("abm_dymamic"
				zeroing(3.0)
				dispersion(0.20)
			)
		}
		{place "mgun2"
			{type "coaxial"}
			{weapon "besa" filling "ammo mgun_ger belt mk2" 225}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "commander"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 11000}
	{Chassis "wheel"
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_btr"
			speed(58) ;----------------------------------Max speed.
			speedatmaxturn(25) ;-------------------------Max speed at max turn.
			reverse(12) ;--------------------------------Max speed in Reverse.
			weight(11.0) ;-------------------------------Weight in Tonnes.
			power(105) ;---------------------------------Horse Power.
			fuel(95) ;----------------------------------Fuel capacity in Litres.
			type(diesel) ;-------------------------------Fuel type.
			range(400) ;---------------------------------Range in Kilometers.
		)
	}
	{bone "gun_rot"
		{limits -15 15}
		{speed2 8} ;// manual using gunner's shoulder
	}
	{bone "turret"
		("turret_light" power_traverse(0)) ;// manual
	}
}