{game_entity
	(include "/properties/vehicle_xx.ext")
	{extension "morris_cs9_xx.mdl"}

	{volume "wheelleft2" {thickness 0.5}}
	{volume "wheelleft1" {thickness 0.5}}
	{volume "wheelright2" {thickness 0.5}}
	{volume "wheelright1" {thickness 0.5}}

	{volume "engine1" {thickness 7}}
	{volume "engine2" {thickness 7}}
	{volume "engine3" {thickness 7}}

	{volume "body1" {thickness 7}}
	{volume "body2" {thickness 7} {able {holed}}}
	{volume "body3" {thickness 7}}
	{volume "body4" {thickness 7}}
	{volume "body5" {thickness 7}}
	{volume "body6" {thickness 7}}
	{volume "body7" {thickness 7}}

	{volume "turret1" {thickness 7} {able {holed}}}
	{volume "turret2" {thickness 7} {able {holed}}}
	{volume "turret3" {thickness 7} {able {holed}}}
	{volume "turret4" {thickness 7} {able {holed}}}

	;// Non-Component Volumes
	{volume "armor1" {thickness 7} {able {holed}}}
	{volume "armor2" {thickness 7}}
	{volume "armor3" {thickness 7}}

	;// Parts
	{volume "part1" {thickness 7}} ;// Visor
	{volume "part2" {thickness 7}{able {contact 0}{obstacle 0}}} ;// Right Door
	{volume "part3" {thickness 7}} ;// Rear (Escape Hatch) Door
	{volume "part4" {thickness 7}{able {contact 0}{obstacle 0}}} ;// Left Door
	{volume "part5_1" {thickness 7}} ;// Left Engine Hatch
	{volume "part5_2" {thickness 7}} ;// Left Engine Hatch
}