{game_entity
	(include "/properties/armoredcar.ext")
	(include "/properties/selection/vehicle.inc" scale(1.0))
	{props "tank" "turret" "wheeled" "with_gun" "vision_lev02" "muzzle_75mm_76mm_sides" "smoke" "2in"}
	{extension "aec_mk3.mdl"}
	{extension "crew.ext"}
	(include "aec_mk3.ext")
	{targetclass "armoredcar"}
	{targetSelector "tank_light"}
	{patherId "sdkfz232"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	{extender "smokescreen"
		{cooldown 5}
		{itemTags "mortareng_50 sm"}
	}

	{extender "inventory"
		{box
			{item "bulletusa_75x350 apcbc" 14}		;40 rounds
			{item "bulletusa_75x350 he" 25}
			{item "ammo mgun_ger belt mk2" 3150}	;15 belts (3375 rounds)
			{item "satchel_charge_eng" 1}
			{item "bren_mk2_drum" filled}
			{item "ammo bren_drum_mag" 503}				;600 rounds 7.7mm
			{item "mortareng_50 sm" 18}
			;{item "no36m grenade" 6}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "75mm_qf" filling "bulletusa_75x350 apcbc" 1}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic"
				zeroing(3.0)
				dispersion(0.20)
			)
		}
		{place "mgun2"
			{type "coaxial"}
			{weapon "besa" filling "ammo mgun_ger belt mk2" 225}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "gunner"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 14164}
	{Chassis "wheel"
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_btr"
			speed(66) ;----------------------------------Max speed.
			speedatmaxturn(25) ;-------------------------Max speed at max turn. 
			reverse(12) ;--------------------------------Max speed in Reverse.
			weight(14.16) ;-------------------------------Weight in Tonnes.
			power(158) ;---------------------------------Horse Power.
			fuel(173) ;----------------------------------Fuel capacity in Litres.
			type(diesel) ;-------------------------------Fuel type.
			range(400) ;---------------------------------Range in Kilometers.
		)
	}

	{bone "gun_rot"
		{limits -15 20}
		{speed2 8}
	}
	{bone "turret"
		("turret_medium" power_traverse(24)) ;// electric
	}
}