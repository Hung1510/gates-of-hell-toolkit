{game_entity
	(include "/properties/armoredcar.ext")
	(include "/properties/selection/vehicle.inc" scale(0.9))
	{props "tank" "wheeled" "vision_lev02" "detect_tank_mg"}
	{extension "humber_scout.mdl"}
	(include "humber_scout.ext")
	{targetclass "armoredcar_l"}
	{targetSelector "tank_bullet"}
	{patherId "sdkfz232"}
	{extension "crew.ext"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	{extender "inventory"
		{weapon "mgun1" {mask "mountable"}}
		{box
			{item "bren_mk2_drum" filled {user "mgun1"}}
			{item "bren_drum_mag ammo" 1000}				;// ~1000 rounds
			{item "satchel_charge_eng" 1}
			;{item "no36m grenade" 6}
		}
	}

	{Weaponry
		{place "mgun1"
			{type "main"}
			{gunner "gunner"}
			{charger "gunner"}
			{LinkBone "mgun1"}
			{LinkAnimation "off"}
			("abm_mgun")
			{ai_in_manual}
			{basic}
		}
	}

	{mass 2400}
	{Chassis "wheel"
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_btr"
			speed(100) ;----------------------------------Max speed.
			speedatmaxturn(25) ;-------------------------Max speed at max turn. 
			reverse(20) ;--------------------------------Max speed in Reverse.
			weight(2.4) ;-------------------------------Weight in Tonnes.
			power(87) ;---------------------------------Horse Power.
			fuel(88) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;-------------------------------Fuel type.
			range(320) ;---------------------------------Range in Kilometers.
		)
	}

	{bone "mgun_h_rot1"
		{speed2 20}		;//remote controlled from inside
	}
	{bone "mgun_h_rot2"
		{limits -10 40}
		{speed2 10}
	}
}
