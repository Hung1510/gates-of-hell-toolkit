{game_entity
	(include "/properties/armoredcar.ext")
	(include "/properties/selection/vehicle.inc" scale(1.0))
	{props "tank" "turret" "wheeled" "with_gun" "vision_lev02" "muzzle_75mm_76mm_sides" "smoke" "2in_wp"}
	{extension "staghound_mk3.mdl"}
	{extension "crew.ext"}
	(include "staghound_mk3.ext")
	{targetclass "armoredcar"}
	{targetSelector "tank_light"}
	{patherId "sdkfz232"}

	{extender "smokescreen"
		{cooldown 5}
		{itemTags "mortareng_50 wp"}
	}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	{extender "inventory"
		{box
			{item "bulletusa_75x350 apcbc" 19}		;// 50 rounds
			{item "bulletusa_75x350 he" 30}
			{item "ammo mgun_ger belt mk2" 4725}	;// 4950 rounds
			{item "satchel_charge_eng" 1}
			{item "mortareng_50 wp" 18}				;// 18 smoke bombs
			;{item "no36m grenade" 6}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "75mm_qf" filling "bulletusa_75x350 apcbc" 1}
			{gunner "gunner"}
			{charger "commander"}
			("abm_dymamic"
				zeroing(3.0)
				dispersion(0.20)
			)
		}
		{place "mgun2"
			{type "coaxial"}
			{weapon "besa" filling "ammo mgun_ger belt mk2" 225}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "commander"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 15000}
	{Chassis "wheel"
		("car_trace" fx("tracewheel01a") step(0.1) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel01a") step(0.1) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_btr"
			speed(88) ;----------------------------------Max speed.
			speedatmaxturn(25) ;-------------------------Max speed at max turn. 
			reverse(21) ;--------------------------------Max speed in Reverse.
			weight(15) ;-------------------------------Weight in Tonnes.
			power(194) ;---------------------------------Horse Power. Each engine generates (two of them are inside) 97 horsepower so 2 times 97 = 194 (DOUBLE CHECK ON MK3)
			fuel(230) ;----------------------------------Fuel capacity in Litres. Base fuel is 230L + Externa Fuel is 140L, so carries 370L of fuel (Mk1 Mk2)
			type(fuel) ;-------------------------------Fuel type.
			range(250) ;---------------------------------Range in Kilometers.
		)
	}

	{bone "gun_rot"
		{limits -7 20}
		{speed2 8}
	}
	{bone "turret"
		("turret_medium" power_traverse(36)) ;// hydraulic
	}
}
