{game_entity
	(include "/properties/armoredcar.ext")
	(include "/properties/selection/vehicle.inc" scale(0.9))
	{props "tank" "turret" "wheeled" "explosion_throw_crew" "vision_lev02" "detect_tank_mg" "smoke" "4in"}
	{extension "humber_recon_mk2.mdl"}
	(include "humber_recon_mk2.ext")
	{targetclass "armoredcar"}
	{targetSelector "tank_bullet"}
	{patherId "sdkfz232"}
	{extension "crew.ext"}

	{extender "enumerator"
		{digit_folder "us2"}
	}
	{extender "smokescreen"
		{cooldown 10} ;// smoke launcher outside vehicle
		{itemTags "grenade no8_smoke"}
	}

	{extender "inventory"
		{weapon "mgun1" {mask "mountable"}}
		{weapon "mgun2" {mask "mountable"}}
		{box
			{item "bren_mk2" filled {user "mgun1"}}
			{item "boys_mk1" filling "atrifle_eng ap2 ammo" {user "mgun2"}}
			{item "atrifle_eng ap2 ammo" 40}		;40 rounds .55
			{item "bren_mag ammo" 2000}				;2000 rounds 7.7mm
			{item "satchel_charge_eng" 1}
			{item "no8_smoke grenade" 8}			;8 smoke grenades
			;{item "no36m grenade" 6}
		}
	}

	{Weaponry
		{place "mgun1"
			{type "aa"}
			{gunner "commander"}
			{charger "commander"}
			{LinkBone "mgun1"}
			{LinkAnimation "off"}
			("abm_mgun")
			{ai_in_manual}
			{basic}
		}
		{place "mgun2"
			{type "main"}
			{gunner "gunner"}
			{charger "gunner"}
			{LinkBone "mgun2"}
			{LinkAnimation "off"}
			("abm_mgun")
			{ai_in_manual}
			{basic}
		}
	}

	{mass 3170}
	{Chassis "wheel"
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_btr"
			speed(72) ;----------------------------------Max speed.
			speedatmaxturn(20) ;-------------------------Max speed at max turn. 
			reverse(19.5) ;--------------------------------Max speed in Reverse.
			weight(3.17) ;-------------------------------Weight in Tonnes.
			power(87) ;---------------------------------Horse Power.
			fuel(72) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;-------------------------------Fuel type.
			range(305) ;---------------------------------Range in Kilometers.
		)
	}

	{bone "mgun2_h_rot1" ;// Boys turret
		{speed2 60}
	}

	{bone "mgun2_h_rot2"	;// Boys rot
		{speed2 60}
	}

	{bone "gun_rot" ;// Bren metal rot
		{limits -10 17}
		{speed2 60}
	}

	{bone "mgun1_h_rot1" ;// Bren extra fake turret (Fixes issues with main turret (mesh) not rotating.
		{speed2 60}
	}

	{bone "mgun1_h_rot2" ;// Bren extra fake rot
		{speed2 60}
	}
}
