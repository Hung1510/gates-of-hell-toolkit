{game_entity
	(include "/properties/marine.ext")
	(include "/properties/selection/vehicle_big.inc" scale(1.3))
	{props "marine" "engine" "searchlight" "vision_lev04_boat" "muzzle_37mm_47mm" "emit_on_sink" "explosion_throw_crew" "boat" "big"}
 	{targetClass "car"}
	{targetSelector "cannon_zenite"}
	{patherID "water"}
	{extension "drifter_eng.mdl"}
	(include "drifter_eng.ext")
	{extension "crew.ext"}
	{extender "enumerator"
		{digit_folder "us2"}
	}

	{extender "inventory"
		{box
			{Weight 90000}
			{item "bullet_57x307 eng he" 900}
			{item "bullet_57x307 eng ap" 100}
		}
	}

	{Weaponry
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "57mm_qf6_hotchkiss" filling "bullet_57x307 eng he" 1}
			{foresight "foresight1"}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic_gun_boat"
				zeroing(2.5)
				dispersion(0.20)
			)
			{basic}
			{ai_in_manual}
		}
		{place "gun1"
			{type "searchlight"}
			{weapon "searchlight"}
			{foresight "foresight6"}
			{gunner "gunner2"}
			{basic}
			{ai_in_manual}
			{rotate}
		}
	}

	{mass 50000}
	{chassis "water"
		("mobility_medium_boat"
			speed(17) ;---------------------------------Max speed.
			speedatmaxturn(8) ;------------------------Max speed at max turn.
			reverse(6) ;-------------------------------Max speed in Reverse.
			weight(50) ;-------------------------------Weight in Tonnes. 45-60
			power(400) ;-------------------------------Horse Power.
			fuel(6630) ;--------------------------------Fuel capacity in Litres. ;// 5.1 t of fuel @ ~0.7 kg per liter
			type(fuel) ;--------------------------------Fuel type.
			range(547) ;--------------------------------Range in Kilometers. ;// ~340 miles @ 26 knots
		)
		{waterline 0}
	}
	
	{bone "turret"
		{speed2 20}
	}
	{bone "gun_rot"
		{limits -20 40}
		{speed2 15}
	}
	{bone "gun_2_rot2"
		{limits -20 60}
		{speed2 20}
	}
}
