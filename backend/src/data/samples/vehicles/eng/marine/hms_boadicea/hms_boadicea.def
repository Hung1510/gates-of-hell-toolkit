			{foresight "foresight1e"}
			{gunner "gunner11"}
			{charger "charger10"}
			("abm_dymamic_aaa"
				zeroing(1.95)
				dispersion(0.24)
			)
			{basic}
			{ai_in_manual}
		}
	}

	{mass 1380000}
	{chassis "water"
		("mobility_medium_boat"
			speed(65) ;---------------Max speed.
			speedatmaxturn(20) ;------Max speed at max turn.
			reverse(20) ;-------------Max speed in Reverse.
			weight(1380) ;------------Weight in Tonnes.
			power(34000) ;------------Horse Power.
			fuel(6630) ;--------------Fuel capacity in Litres. ;// 5.1 t of fuel @ ~0.7 kg per liter
			type(fuel) ;--------------Fuel type.
			range(8900) ;-------------Range in Kilometers. ;// ~340 miles @ 26 knots
		)
		{waterline 0}
	}

