{game_entity
	(include "/properties/marine.ext")
	(include "/properties/selection/vehicle_big.inc" scale(1.3))
	{props "marine" "engine" "vision_lev05_boat" "muzzle_122mm_128mm" "emit_on_sink" "explosion_throw_crew" "boat" "big"}
 	{targetClass "armoredcar"}
	{targetSelector "cannon_howitzer"}
	{patherID "water"}
	{extension "hms_boadicea.mdl"}
	(include "hms_boadicea.ext")
	{extension "crew.ext"}

	{extender "inventory"
		{box
			{Weight 100000}
			{item "bulleteng_120 he" 920} 	;// 190 + 40 (during wartime) per 120mm gun = 230 total per gun, full total = 920
			{item "bullet_40x158mm_auto eng he" 1000} 	;// 500 per AA = 1000 in total
		}
	}

	{Weaponry
		{place "gun"
			{RestoreIKAfterAim}
