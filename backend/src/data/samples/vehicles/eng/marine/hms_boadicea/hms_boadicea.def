			{foresight "foresight1c"}
			{gunner "gunner7"}
			{charger "charger7"}
			("abm_dymamic_gun_boat"
				zeroing(2.5)
				dispersion(0.20)
			)
			{basic}
			{ai_in_manual}
		}
		{place "gun4"
			{RestoreIKAfterAim}
			{weapon "40mm_qf2_vickers" filling "bullet_40x158mm_auto eng he" 25}
			{foresight "foresight1d"}
			{gunner "gunner9"}
			{charger "charger9"}
			("abm_dymamic_aaa"
				zeroing(1.95)
				dispersion(0.24)
			)
			{basic}
			{ai_in_manual}
		}
		{place "gun5"
			{RestoreIKAfterAim}
