{game_entity
	(include "/properties/marine.ext")
	(include "/properties/selection/vehicle_big.inc" scale(1.3))
	{props "marine" "vision_lev03_boat" "open_without_land" "emit_on_sink" "multi_board" "explosion_throw_crew" "car"}
 	{targetClass "car"}
	{targetSelector "tank_bullet"}
	{patherid "shallow_water_0"}
	{extension "lca.mdl"}
	(include "lca.ext")
	{extension "crew.ext"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	{extender "inventory"
		{weapon "mgun" {mask "mountable"}}
		{box
			{item "bren_mk2" filled {user "mgun"}}
			{item "bren_mag ammo" 900}
		}
	}

	{Weaponry
;		("restore_ik_time")
		{place "mgun"
			{type "hull"}
			{gunner "gunner"}
			{charger "gunner"}
			{LinkBone "mgun_rot"}
			{LinkAnimation "off"}
			("abm_mgun")
			{basic}
			{ai_in_manual}
		}
	}

	{mass 9144}
	{chassis
		{Locomotion ("locomotion")
			{TurnRadius	4}
			{MaxSpeed	19}
			{StartTime	18}
			{BrakeTime	6}
			{TurnTime	45}
		}
	}

	{bone "mgun_h_rot1"
		{limits -10 55}
	}
}
