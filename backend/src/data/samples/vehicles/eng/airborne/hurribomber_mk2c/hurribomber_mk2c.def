{game_entity
	(include "/properties/airborne.ext")
	(include "/properties/selection/airborne.inc" scale(1.5))
	{props "wheeled" "vision_lev01_air"}
	{extension "hurribomber_mk2c.mdl"}
	{PatherID "p47"}


	("fighter_tier2")

	{boarder
		{anm "driver"
			{forward {begin "board_plane_left"} {end "seat_driver_car"} {base "open"}}
			{reverse {end "board_plane_left" -1} {base "open" -1}}
		}
	}

	("crew_human" place(driver) bone(driver) door(emit1) animation(driver) group(crew))

	{Placer
		{place "driver" {turnOff {targetable}}}
	}

	("single_engine")

	("wheel" args "wheelr")
	("wheel" args "wheell")
	("wheel" args "wheel1")

	{volume "engine1" {material "steel"}}


	{Chassis "wheel"
		("car_trace" fx("tracewheel05") step(0.07) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
	}

	{Chassis "airborne"
		("flight_model"
			speed(545) ;//----------Max speed (at sea level), km/h.
			climb_speed(6) ;//------Climb rate at sea level, in m/s
			turn(180) ;//-----------Turn-and-burn radius in meters, tightest sustained turn
			turnMP(150) ;//---------Turn-and-burn radius in meters, tightest sustained turn
			aerodynamics(2.5) ;//---Aerodynamic efficiency rating (0-3)
			weight(2630) ;//--------Weight in kg.
			power(1280) ;//----------Horse Power.
			fuel(355) ;//-----------Fuel capacity in Liters.
			range(740) ;//----------Distance can travel with full fuel tank, in km.
			roll_rate(20) ;//-------Roll rate, in degrees per second.
			roll_angle(45) ;//------Maximum roll angle, in degrees.
		)
	}

	{mass 2630}

	{extender "inventory"
		{box
			;{item "ammo hmgun_usa  api" 2560}
		}
	}

	{Weaponry
		{place "gun"
			{weapon "20mm_hispano_mk2_hur_x4" filled}
			{barrels 4}
			{foresight "foresight1"}
			{shooter "shooter"}
			{charger "driver"}
			{gunner "driver"}
			{ai_in_manual}
			{basic}
		}
		{place "bomb1"
			{weapon "bomb_dropper_eng_100x2" filled}
			{barrels 2}
			{gunner "driver"}
			{shooter "shooter_bb"}
			{charger "driver"}
			{basic}
		}
	}

	("mp_gun_limits")
}
