{game_entity
	(include "/properties/airborne.ext")
	(include "/properties/selection/airborne.inc" scale(2.25))
	{props "wheeled" "wood" "-steel" "vision_lev01_air"}
	{extension "horsa_mk1.mdl"}
	{PatherID "blenheim"}

	("fighter_tier2")

	{boarder
		{anm "driver"
			{forward {begin "board_c47"} {end "c47_driver_pose"}}
			{reverse {end "emit_plane_parachute" -1}}
		}
		{anm "commander"
			{forward {begin "board_c47"} {end "c47_driver_pose"}}
			{reverse {end "emit_plane_parachute" -1}}
		}
		{anm "passenger"
			{forward {begin "board_c47"} {end "seat_passenger"}}
			{reverse {end "emit_plane_parachute" -1}}
		}
		{anm "passenger1"
			{forward {begin "board_c47"} {end "c47_paradrop_pose"}}
			{reverse {end "emit_plane_parachute" -1}}
		}
	}

	("crew_human" place(driver) bone(driver) door(emit1) animation(driver) group(crew))
	("crew_human" place(commander) bone(commander) door(emit1) animation(commander) group(crew))

	{Placer
		{place "driver" {visor "main"} {turnOff {targetable}}}
		{place "commander" {visor "around"} {turnOff {targetable}}}
	}

	("passenger_horsa")
	("passenger_human" place(seat1) bone(seat01) door(emit1) animation(passenger1) group(passenger))

	("single_engine")
	("wheel" args "wheelr")
	("wheel" args "wheell")
	("wheel" args "wheel1")

	{volume "gear_l" {material "steel"}}
	{volume "gear_r" {material "steel"}}
	{volume "wheell" {material "steel"}}
	{volume "wheelr" {material "steel"}}
	{volume "wheel1" {material "steel"}}
	{volume "body1" {able {holed}}}
	{volume "wingL2" {able {holed}}}
	{volume "wingR2" {able {holed}}}
	{volume "door" {able {visible 0}}}

	{Chassis "wheel"
		("car_trace" fx("tracewheel05") step(0.07) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
	}

	{mass 6920}
	{Chassis "airborne"
		("flight_model"
			speed(150) ;//----------Max speed (at sea level), km/h.
			climb_speed(5) ;//------Climb rate at sea level, in m/s
			turn(180) ;//-----------Turn-and-burn radius in meters, tightest sustained turn
			turnMP(33) ;//----------Turn-and-burn radius in meters, tightest sustained turn
			aerodynamics(0.5) ;//---Aerodynamic efficiency rating (0-3)
			weight(6920) ;//--------Weight in kg.
			power(1237) ;//---------Horse Power.
			fuel(1000) ;//----------Fuel capacity in Liters.
			range(1000) ;//---------Distance can travel with full fuel tank, in km.
			roll_rate(20) ;//-------Roll rate, in degrees per second.
			roll_angle(45) ;//------Maximum roll angle, in degrees.
		)
	}

	{extender "inventory"
		{box}
	}
}
