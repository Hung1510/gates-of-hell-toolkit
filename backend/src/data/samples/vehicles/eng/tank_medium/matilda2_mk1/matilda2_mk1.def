{game_entity
	(include "/properties/tank.ext")
	(include "/properties/selection/vehicle.inc" scale(1.0))
	{props "medium" "vision_lev04" "muzzle_37mm_47mm" "smoke" "4in_2x"}
	{extension "matilda2_mk1.mdl"}
	(include "matilda2_mk1.ext")
	{PatherID "matilda2"}
	{targetclass "tank_medium"}
	{targetSelector "tank_light"}

	("crew_4_human_extended")

	{boarder
		{anm "driver"
			{forward {begin "board_t26_driver"} {end "pose_t26_driver"} {base "open_driver"}}
			{reverse {end "board_t26_driver" -1} {base "open_driver" -1}}
		}
		{anm "left"
			{forward {begin "board_kv"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "right"
			{forward {begin "board_tank_right"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "armor"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_armor_1"}}
			{reverse {end "emit_tank_1"}}
		}
		{anm "armor1"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_armor_2"}}
			{reverse {end "emit_body"}}
		}
	}

	("seat_human" place(seat1) bone(seat01) door(emit3) animation(armor))
	("seat_human" place(seat2) bone(seat02) door(emit4) animation(armor))
	("seat_human" place(seat3) bone(seat03) door(emit5) animation(armor1))
	("seat_human" place(seat4) bone(seat04) door(emit6) animation(armor1))
	("seat_human" place(seat5) bone(seat05) door(emit7) animation(armor))
	("seat_human" place(seat6) bone(seat06) door(emit8) animation(armor1))

	{extender "smokescreen"
		{cooldown 5}
		{itemTags "grenade no8_smoke"}
	}

	{extender "inventory"
		{box
			{item "bulleteng_40 ap2" 92}				; 93 rounds
			{item "ammo mgun_eng belt" 2250}			; 13 belts (250 rounds each)
			{item "satchel_charge_eng" 1}
			{item "no8_smoke grenade" 8}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "40mm_qf2_2" filling "bulleteng_40 ap2" 1}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic"
				zeroing(2.5)
				dispersion(0.20)
			)
		}
		{place "mgun2"
			{type "coaxial"}
			{weapon "vickers_tank" filled}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "charger"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 26500}
	{Chassis
		("tank_trace" fx("tracks_sm2") step(0.17) len(-0.77))
		("mobility_tank"
			speed(24) ;----------Max speed when fully accelerated on road, km/h.
			reverse(5) ;---------Max speed in reverse on road, km/h.
			traverse(25) ;-------Track traverse, per second, in degrees.
			weight(26.5) ;-------Weight in Tonnes.
			power(174) ;---------Engine Power, in hp.
			track(9.5) ;---------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(181) ;----------Fuel capacity in Litres.  ;// 40 imp. gal
			type(diesel) ;-------Fuel type. (diesel OR fuel)
			range(80) ;----------Range in km, off-road.
		)
	}

	{bone "gun_rot"
		{limits -15 20}
		{speed2 10}
	}
	{bone "turret"
		("turret_medium" power_traverse(24)) ;// hydraulic
	}
}