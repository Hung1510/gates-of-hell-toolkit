{game_entity
	(include "/properties/tank.ext")
	(include "/properties/selection/vehicle.inc" scale(1.1))
	{props "medium" "vision_lev04" "muzzle_75mm_76mm_sides" "smoke" "2in_wp" "cromwell_mk4"}
	{extension "../cromwell4/cromwell5.mdl"}
	(include  "../cromwell4/cromwell5.ext")
	{PatherId "cromwell"}
	{targetclass "tank_medium"}
	{targetSelector "tank_medium"}
	{extender "smokescreen"
		{cooldown 5}
		{itemTags "mortareng_50 wp"}
	}
	{extender "shield" {on}}
	{extender "enumerator"
		{digit_folder "us2"}
	}

	("crew_5_human_extended2")

	{boarder
		{anm "driver"
			{forward {begin "board_lowarmor"} {end "seat_m4_gunner"}}
			{reverse {end "emit_tank_1_hold"} {base "open_driver"}}
		}
		{anm "co_driver"
			{forward {begin "board_lowarmor"} {end "seat_m4_gunner"}}
			{reverse {end "emit_tank_1_hold"} {base "open_driver"}}
		}
		{anm "left"
			{forward {begin "board_cromwell"} {end "seat_m4_gunner"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "right"
			{forward {begin "board_cromwell"} {end "seat_m4_gunner"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "armor1"
			{forward {begin "board_lowarmor"} {end "pose_seat_cromwell4_01"}}
			{reverse {end "emit_tank_2"}}
		}
		{anm "armor2"
			{forward {begin "board_lowarmor"} {end "pose_seat_cromwell4_00"}}
			{reverse {end "emit_tank_2"}}
		}
		{anm "armor3"
			{forward {begin "board_lowarmor"} {end "pose_seat_cromwell4_02"}}
			{reverse {end "emit_tank_2"}}
		}
		{anm "armor4"
			{forward {begin "board_lowarmor"} {end "pose_seat_cromwell4_03"}}
			{reverse {end "emit_tank_2"}}
		}
	}

	("seat_human" place(seat1) bone(seat01) door(emit4) animation(armor1))
	("seat_human" place(seat2) bone(seat02) door(emit5) animation(armor2))
	("seat_human" place(seat3) bone(seat03) door(emit6) animation(armor3))
	("seat_human" place(seat4) bone(seat04) door(emit7) animation(armor4))

	{extender "inventory"
		{box
			{item "ammo bulletusa_75x350 apcbc" 25}			; 64 rounds
			{item "ammo bulletusa_75x350 he" 38}
			{item "ammo mgun_ger belt mk2" 4500}			; 7.92mm, 4950 rounds
			{item "bren_mk2" filled}
			{item "ammo bren_mag" 572}					;600 rounds 7.7mm
			;{item "no36m grenade" 6}
			{item "satchel_charge_eng" 1}
			{item "mortareng_50 wp" 30}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "75mm_qf" filling "ammo bulletusa_75x350 apcbc" 1}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic"
				zeroing(3)
				dispersion(0.2)
			)
		}
		{place "mgun2"
			{type "coaxial"}
			{weapon "besa" filling "ammo mgun_ger belt mk2" 225}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "charger"}
			("abm_mgun")
			{basic}
		}
		{place "mgun1"
			{type "hull"}
			{weapon "besa" filling "ammo mgun_ger belt mk2" 225}
			{foresight "foresight4"}
			{gunner "gunner3"}
			{charger "gunner3"}
			("abm_mgun")
			{basic}
			{ai_in_manual}
		}
	}

	{mass 28000}
	{Chassis
		("tank_trace" fx("tracks_mid") step(0.2) len(0.63))
		("mobility_tank"
			speed(52) ;----------Max speed when fully accelerated on road, km/h.
			reverse(6) ;---------Max speed in reverse on road, km/h.	;// 4 kmp + 2 due to offroad multiplier
			traverse(30) ;-------Track traverse, per second, in degrees.
			weight(28.0) ;-------Weight in Tonnes.
			power(600) ;---------Engine Power, in hp.
			track(3) ;-----------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(530) ;----------Fuel capacity in Litres.
			type(fuel) ;---------Fuel type. (diesel OR fuel)
			range(270) ;---------Range in km, off-road.
		)
	}

	{bone "gun_rot"
		{limits -12 20}
		{speed2 5}
	}
	{bone "turret"
		("turret_medium" power_traverse(25)) ;// hydraulic drive
	}
}