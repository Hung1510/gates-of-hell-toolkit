{game_entity		;// july '42
	(include "/properties/tank_assaultgun.ext")
	(include "/properties/selection/vehicle.inc" scale(1.0))
	{props "medium" "spg" "-turret" "vision_lev04" "muzzle_85mm_93mm" "tractor" "tractor_light" "detect_artillery" "artillery_minimap_medium"}
	{extension "bishop.mdl"}
	(include "bishop.ext")
	{PatherID "matilda2"}
	{targetclass "tank_medium"}
	{targetSelector "cannon_howitzer"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	("crew_4_human_extended")

	{boarder
		{anm "driver"
			{forward {begin "board_t26_driver"} {end "pose_t26_driver"} {base "open_driver"}}
			{reverse {end "board_t26_driver" -1} {base "open_driver" -1}}
		}
		{anm "left"
			{forward {begin "board_kv"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "right"
			{forward {begin "board_tank_right"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "armor"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_armor_1"}}
			{reverse {end "emit_tank_1"}}
		}
		{anm "armor1"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_armor_2"}}
			{reverse {end "emit_body"}}
		}
	}

	("seat_human" place(seat1) bone(seat01) door(emit3) animation(armor))
	("seat_human" place(seat2) bone(seat02) door(emit4) animation(armor))
	("seat_human" place(seat3) bone(seat03) door(emit5) animation(armor1))
	("seat_human" place(seat4) bone(seat04) door(emit6) animation(armor1))
	("seat_human" place(seat5) bone(seat05) door(emit7) animation(armor))
	("seat_human" place(seat6) bone(seat06) door(emit8) animation(armor1))


	{extender "inventory"
		{box
			{item "ammo bulleteng_88 he" 21}			;32 rounds
			{item "ammo bulleteng_88 ap" 5}
			{item "ammo bulleteng_88 sm" 5}
			{item "bren_mk2_drum" filled}
			{item "ammo bren_drum_mag" 503}				;600 rounds
			{item "satchel_charge_eng" 1}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "88mm_qf25_bishop" filling "bulleteng_88 he" 1}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic"
				zeroing(4.0)
				dispersion(0.25)
			)
		}
	}

	{mass 17500}
	{Chassis
		("tank_trace" fx("tracks_sm2") step(0.17) len(0.61))
		("mobility_tank"
			speed(24) ;----------Max speed when fully accelerated on road, km/h.
			reverse(5) ;---------Max speed in reverse on road, km/h.
			traverse(25) ;-------Track traverse, per second, in degrees.
			weight(17.5) ;-------Weight in Tonnes.
			power(131) ;---------Engine Power, in hp.
			track(7.5) ;---------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(163) ;----------Fuel capacity in Litres.
			type(diesel) ;-------Fuel type. (diesel OR fuel)
			range(110) ;---------Range in km, off-road.
		)
	}

	{bone "gun_rot"
		{limits -5 15}
		{speed2 8}
	}
	{bone "turret"
		{limits -4 4}
		{speed2 8}
	}
}