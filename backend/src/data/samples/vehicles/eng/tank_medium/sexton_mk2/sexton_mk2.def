{game_entity
	(include "/properties/tank.ext")
	(include "/properties/selection/vehicle.inc" scale(1.1))
	{props "spg" "medium" "-turret" "vision_lev04" "muzzle_85mm_93mm_sides" "shell_eject" "detect_artillery" "artillery_minimap_medium"  "open_top" "ammo_open_top"}
	{extension "sexton_mk2.mdl"}
	(include  "sexton_mk2.ext")
	{PatherId "sherman"}
	{targetclass "tank_medium"}
	{targetSelector "cannon_howitzer"}
	
	{extender "enumerator"
		{digit_folder "us2"}
	}

	{boarder
		{anm "driver_l"
			{forward {begin "board_tank_left"} {end "seat_m7_driver"}}
			{reverse {end "emit_tank_2_hold"}}
		}
		{anm "driver_r"
			{forward {begin "board_tank_right"} {end "seat_m7_driver"}}
			{reverse {end "emit_tank_2_hold"}}
		}
		{anm "gunner_l"
			{forward {begin "board_tank_left"} {end "pose_m5_gunlayer"}}
			{reverse {end "emit_tank_2_hold"}}
		}
		{anm "gunner_r"
			{forward {begin "board_tank_right"} {end "pose_m5_gunlayer"}}
			{reverse {end "emit_tank_2_hold"}}
		}
		{anm "gunner2_l"
			{forward {begin "board_tank_left"} {end "pose_univ_carrier_gunner2b"}}
			{reverse {end "emit_tank_2_hold"}}
		}
		{anm "gunner2_r"
			{forward {begin "board_tank_right"} {end "pose_univ_carrier_gunner2b"}}
			{reverse {end "emit_tank_2_hold"}}
		}
		{anm "charger_l"
			{forward {begin "board_tank_left"} {end "pose_pdr25_charger"}}
			{reverse {end "emit_tank_2_hold"}}
		}
		{anm "charger_r"
			{forward {begin "board_tank_right"} {end "pose_pdr25_charger"}}
			{reverse {end "emit_tank_2_hold"}}
		}
		{anm "charger2_l"
			{forward {begin "board_tank_left"} {end "pose_flak_commander"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "charger2_r"
			{forward {begin "board_tank_right"} {end "pose_flak_commander"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "commander_l"
			{forward {begin "board_tank_left"} {end "seat_m18_charger"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "commander_r"
			{forward {begin "board_tank_right"} {end "seat_m18_charger"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "armor1"
			{forward {begin "board_HighArmor"} {end "pose_seat_armor_1"}}
			{reverse {end "emit_tank_2"}}
		}
	}

	("crew_human_visible_anm"  place(driver)	door(emit1) door2(emit2) visor(driver)	anm_left(driver_l)		anm_right(driver_r))
	("crew_human_visible_anm"  place(gunner)	door(emit3) door2(emit4) visor(main)	anm_left(gunner_l)		anm_right(gunner_r))
	("crew_human_visible_anm2" place(gunner2)	door(emit3) door2(emit4) visor()		anm_left(gunner2_l)		anm_right(gunner2_r))
	("crew_human_visible_anm2" place(charger)	door(emit3) door2(emit4) visor()		anm_left(charger_l)		anm_right(charger_r))
	("crew_human_visible_anm2" place(charger2)	door(emit3) door2(emit4) visor()		anm_left(charger2_l)	anm_right(charger2_r))
	("crew_human_visible_anm"  place(commander)	door(emit1) door2(emit2) visor(around)	anm_left(commander_l)	anm_right(commander_r))

	("seat_human" place(seat1) bone(seat01) door(emit5) animation(armor1))
	("seat_human" place(seat2) bone(seat02) door(emit6) animation(armor1))
	;("seat_human" place(seat3) bone(seat03) door(emit7) animation(armor1))
	;("seat_human" place(seat4) bone(seat04) door(emit8) animation(armor1))

	{extender "inventory"
		;{weapon "mgun2" {mask "mountable"}}
		{box
			{item "ammo bulleteng_88 he" 79}	;105 rounds
			{item "ammo bulleteng_88 ap" 15}
			{item "ammo bulleteng_88 sm" 10}
			;{item "bren_mk2" filled {user "mgun2"}}
			{item "ammo bren_mag" 1444}			;1500 rounds
			{item "bren_mk2" filled}
			{item "satchel_charge_eng" 1}
		}
	}
	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "88mm_qf25_mk2_late" filling "bulleteng_88 he" 1}
			{gunner "gunner"}
			{charger "charger charger2" minWorkers 1}
			{rotate}
			("abm_dymamic_gun"
				zeroing(4.0)	; // time it takes to aim until the reticle shrinks. Bigger values, more control.
				dispersion(1)   ; // time it takes to distort the reticle when you move the gun (how abrupt it loses zeroing). Bigger values, more control.
			)
		}
		{place "mgun2"
			{type "main"}
			{weapon "bren_mk2" filled}
			{gunner "gunner2"}
			{charger "gunner2"}
			{LinkBone "mgun2"}
			("abm_mgun")
			{ai_in_manual}
			{basic}
		}
	}

	{mass 25860}
	{Chassis
		("tank_trace" fx("tracks_mid") step(0.3) len(0.66))
		("mobility_tank"
			speed(40) ;----------Max speed when fully accelerated on road, km/h.
			reverse(6) ;---------Max speed in reverse on road, km/h.
			traverse(30) ;-------Track traverse, per second, in degrees.
			weight(25.86) ;------Weight in Tonnes.
			power(400) ;---------Engine Power, in hp.
			track(4) ;-----------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(635) ;----------Fuel capacity in Litres.
			type(fuel) ;---------Fuel type. (diesel OR fuel)
			range(160) ;---------Range in km, off-road.
		)
	}

	{bone "turret"
		{limits -25 15}
		{speed2 8}
	}
	{bone "gun_rot"
		{limits -9 40}
		{speed2 8}
	}
	{bone "mgun_a_rot1"
		{limits -20 25}
		{speed2 60}
	}
	{bone "mgun_a_rot2"
		{limits -12 55}
		{speed2 60}
	}
	(mod "mp"
		{brain
			{properties
				{fire_mode hold}
			}
		}
	)
}
