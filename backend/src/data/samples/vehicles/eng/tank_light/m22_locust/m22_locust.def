{game_entity
	(include "/properties/tank.ext")
	(include "/properties/selection/vehicle.inc" scale(0.8))
	{props "light" "vision_lev03" "muzzle_37mm_47mm" "detect_tank_light"}
	{extension "m22_locust.mdl"}
	(include "m22_locust.ext")
	{targetclass "tank_light"}
	{targetSelector "tank_light"}
	{patherId "locust"}
	{collider "tank.light"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	("crew_3_human_2_extended")

	{boarder
		{anm "driver"
			{forward {begin "board_t26_driver"} {end "pose_t26_driver"} {base "open_driver"}}
			{reverse {end "board_t26_driver" -1} {base "open_driver" -1}}
		}
		{anm "left"
			{forward {begin "board_tank_left"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "right"
			{forward {begin "board_tank_right"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "armor1"
			{forward {begin "board_lowarmor"} {end "pose_seat_passenger_unic304f_02"}}
			{reverse {end "emit_tank_2"}}
		}
		{anm "armor2"
			{forward {begin "board_lowarmor"} {end "pose_seat_armor_1"}}
			{reverse {end "emit_tank_2"}}
		}
		{anm "armor3"
			{forward {begin "board_lowarmor"} {end "pose_seat_mimosa10"}}
			{reverse {end "emit_tank_2"}}
		}
		{anm "armor4"
			{forward {begin "board_lowarmor"} {end "pose_seat_armor_2"}}
			{reverse {end "emit_tank_2"}}
		}
	}

	("seat_human" place(seat1) bone(seat1) door(emit3) animation(armor1))
	("seat_human" place(seat2) bone(seat2) door(emit4) animation(armor2))
	("seat_human" place(seat3) bone(seat3) door(emit5) animation(armor3))
	("seat_human" place(seat4) bone(seat4) door(emit6) animation(armor4))

	{extender "inventory"
		{box
			{item "bulletusa_37 apcbc" 20}			;50 rounds in total ;40/60% AP/HE
			{item "bulletusa_37 he" 30}
			{item "ammo mgun_usa belt" 2250}		;2500 rounds
			{item "satchel_charge_usa" 1}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "37mm_m6" filling "bulletusa_37 apcbc" 1}
			{gunner "gunner"}
			{charger "commander"}
			("abm_dymamic"
				zeroing(2.5)
				dispersion(0.20)
			)
		}
		{place "mgun2"
			{type "coaxial"}
			{weapon "browning_m19a5" filled}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "commander"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 7400}
	{Chassis
		("tank_trace" fx("tracks_sm2") step(0.2) len(-0.47))
		("mobility_tank"
			speed(56) ;-----------Max speed when fully accelerated on road, km/h.
			reverse(10) ;---------Max speed in reverse on road, km/h.
			traverse(37) ;--------Track traverse, per second, in degrees.
			weight(7.4) ;---------Weight in Tonnes.
			power(162) ;----------Engine Power, in hp.
			track(4.0) ;----------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(215) ;-----------Fuel capacity in Litres.
			type(fuel) ;----------Fuel type. (diesel OR fuel)
			range(170) ;----------Range in km, off-road.
		)
	}

	{bone "gun_rot"
		{limits -10 30}
		{speed2 8}
	}
	{bone "turret"
		("turret_light" power_traverse(0)) ;// manual
	}
}