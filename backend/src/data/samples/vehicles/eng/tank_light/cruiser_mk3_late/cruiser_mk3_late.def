{game_entity
	(include "/properties/tank.ext")
	(include "/properties/selection/vehicle.inc" scale(1))
	{props "cruiser_mk3" "light" "vision_lev03" "muzzle_37mm_47mm" "smoke" "4in_2x" "shield" "detect_tank_light"}
	{extension "../cruiser_mk3/cruiser_mk3_late.mdl"}
	(include "../cruiser_mk3/cruiser_mk3.ext")
	{PatherID "cruiser3"}
	{collider "tank.light"}
	{targetclass "tank_light"}
	{targetSelector "tank_light"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	("crew_4_human_extended")

	{boarder
		{anm "driver"
			{forward {begin "board_t34_driver"} {end "pose_t26_driver"} {base "open_driver"}}
			{reverse {end "board_t26_driver" -1} {base "open_driver" -1}}
		}
		{anm "left"
			{forward {begin "board_kv"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "right"
			{forward {begin "board_tank_right"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "armor"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_armor_1"}}
			{reverse {end "emit_tank_1"}}
		}
		{anm "armor1"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_armor_2"}}
			{reverse {end "emit_body"}}
		}
	}

	("seat_human" place(seat1) bone(seat01) door(emit3) animation(armor))
	("seat_human" place(seat2) bone(seat02) door(emit4) animation(armor))
	("seat_human" place(seat3) bone(seat03) door(emit5) animation(armor1))
	("seat_human" place(seat4) bone(seat04) door(emit6) animation(armor1))
	("seat_human" place(seat5) bone(seat05) door(emit7) animation(armor1))
	("seat_human" place(seat6) bone(seat06) door(emit8) animation(armor1))

	{extender "shield" {on}}

	{extender "smokescreen"
		{cooldown 5}
		{itemTags "grenade no8_smoke"}
	}

	{extender "inventory"
		{box
			{item "bulleteng_40 ap2" 86}					; 87 rounds
			{item "ammo mgun_eng belt" 3500}			; 15 belts (250 rounds each)
			{item "satchel_charge_eng" 1}
			{item "no8_smoke grenade" 8}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "40mm_qf2_2" filling "bulleteng_40 ap2" 1}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic"
				zeroing(2.5)
				dispersion(0.20)
			)
		}
		{place "mgun2"
			{type "coaxial"}
			{weapon "vickers_tank" filled}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "charger"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 14224}
	{Chassis
		("tank_trace" fx("tracks_sm2") step(0.50) len(0.5))
		("mobility_tank"
			speed(48) ;----------Max speed when fully accelerated on road, km/h.
			reverse(6) ;---------Max speed in reverse on road, km/h.
			traverse(32) ;-------Track traverse, per second, in degrees.
			weight(14.2) ;-------Weight in Tonnes.
			power(340) ;---------Engine Power, in hp.
			track(3.8) ;---------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(510) ;----------Fuel capacity in Litres.
			type(fuel) ;---------Fuel type. (diesel OR fuel)
			range(150) ;---------Range in km, off-road.
		)
	}

	{bone "gun_rot"
		{limits -15 20}
		{speed2 10}
	}
	{bone "turret"
		("turret_light" power_traverse(24)) ;// hydraulic
	}
}