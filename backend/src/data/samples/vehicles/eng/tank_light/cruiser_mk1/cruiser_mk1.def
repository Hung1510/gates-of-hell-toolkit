{game_entity
	(include "/properties/tank.ext")
	(include "/properties/selection/vehicle.inc" scale(1))
	{props "light" "multi_turret" "vision_lev03" "muzzle_37mm_47mm" "detect_tank_light"}
	{extension "cruiser_mk1.mdl"}
	(include "cruiser_mk1.ext")
	{PatherID "cruiser"}
	{collider "tank.light"}
	{targetclass "tank_light"}
	{targetSelector "tank_light"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	("crew_inside")
	("crew_driver" door(emit0) door2(emit1) door3(emit2))
	("crew_human" place(gunner)		door(emit1) door2(emit2) visor(main))
	("crew_human" place(gunner3)	door(emit1) door2(emit2) visor(mgun1))
	("crew_human" place(gunner4)	door(emit1) door2(emit2) visor(mgun2))
	("crew_human" place(charger)	door(emit1) door2(emit2) visor(none))
	("crew_human" place(commander)	door(emit1) door2(emit2) visor(around))

	{boarder
		{anm "driver"
			{forward {begin "board_t34_driver"} {end "pose_t26_driver"} {base "open_driver"}}
			{reverse {end "board_t26_driver" -1} {base "open_driver" -1}}
		}
		{anm "left"
			{forward {begin "board_kv"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "right"
			{forward {begin "board_tank_right"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "armor"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_armor_1"}}
			{reverse {end "emit_tank_1"}}
		}
		{anm "armor1"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_armor_2"}}
			{reverse {end "emit_body"}}
		}
	}

	("seat_human" place(seat1) bone(seat01) door(emit3) animation(armor))
	("seat_human" place(seat2) bone(seat02) door(emit4) animation(armor))
	("seat_human" place(seat3) bone(seat03) door(emit5) animation(armor1))
	("seat_human" place(seat4) bone(seat04) door(emit6) animation(armor1))

	{sensor
		{visor "mgun1"
			{vision "tank_rear-mg"}
			{bone "foresight4"}
		}
		{visor "mgun2"
			{vision "tank_rear-mg"}
			{bone "foresight5"}
		}
	}

	{extender "inventory"
		{box
			{item "bulleteng_40 ap2" 99}				; 100 rounds
			{item "ammo mgun_eng belt" 2250}			; 12 belts (250 rounds each)
			{item "satchel_charge_eng" 1}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "40mm_qf2_2" filling "bulleteng_40 ap2" 1}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic"
				zeroing(2.5)
				dispersion(0.20)
			)
		}
		{place "mgun"
			{type "coaxial"}
			{weapon "vickers_tank" filled}
			{foresight "foresight3"}
			{gunner "gunner"}
			{charger "charger"}
			("abm_mgun")
			{basic}
		}
		{place "mgun1"
			{type "mgun_turret_left"}
			{weapon "vickers_tank" filled}
			{foresight "foresight4"}
			{gunner "gunner3"}
			{charger "gunner3"}
			("abm_mgun")
			{basic}
			{ai_in_manual}
		}
		{place "mgun2"
			{type "mgun_turret_right"}
			{weapon "vickers_tank" filled}
			{foresight "foresight5"}
			{gunner "gunner4"}
			{charger "gunner4"}
			("abm_mgun")
			{basic}
			{ai_in_manual}
		}
	}

	{mass 13030}
	{Chassis
		("tank_trace" fx("tracks_sm2") step(0.22) len(-0.95))
		("mobility_tank"
			speed(40) ;----------Max speed when fully accelerated on road, km/h.
			reverse(6) ;---------Max speed in reverse on road, km/h.
			traverse(30) ;-------Track traverse, per second, in degrees.
			weight(13) ;---------Weight in Tonnes.
			power(150) ;---------Engine Power, in hp.
			track(6) ;-----------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(325) ;----------Fuel capacity in Litres.
			type(fuel) ;---------Fuel type. (diesel OR fuel)
			range(150) ;---------Range in km, off-road.
		)
	}

	{bone "gun_rot"
		{limits -15 20}
		{speed2 10}
	}

	{bone "turret"
		("turret_light" power_traverse(24)) ;// hydraulic
	}

	{bone "aux_turret1" ;// Left Auxiliary Turret
		{limits -4 130}
		{speed2 25}
	}

	{bone "aux_turret2" ;// Right Auxiliary Turret
		{limits -110 25}
		{speed2 25}
	}
}