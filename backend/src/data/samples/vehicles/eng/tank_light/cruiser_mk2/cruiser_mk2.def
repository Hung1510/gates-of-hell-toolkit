{game_entity
	(include "/properties/tank.ext")
	(include "/properties/selection/vehicle.inc" scale(1))
	{props "light" "vision_lev03" "muzzle_37mm_47mm" "detect_tank_light"}
	{extension "cruiser_mk2.mdl"}
	(include "cruiser_mk2.ext")
	{PatherID "cruiser2"}
	{collider "tank.light"}
	{targetclass "tank_light"}
	{targetSelector "tank_light"}

	{extender "enumerator"
		{digit_folder "us2"}
	}

	("crew_4_human_extended")

	{boarder
		{anm "driver"
			{forward {begin "board_lowarmor"} {base "open_driver"}}
			{reverse {end "board_lowarmor" -1} {base "open_driver" -1}}
		}
		{anm "left"
			{forward {begin "board_tank_left"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "right"
			{forward {begin "board_tank_right"}}
			{reverse {end "emit_tank_1_hold"}}
		}
		{anm "armor"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_challenger_a30_01"}}
			{reverse {end "emit_tank_1"}}
		}
		{anm "armor1"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_cromwell4_02"}}
			{reverse {end "emit_body"}}
		}
		{anm "armor2"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_sherman5_mid_01"}}
			{reverse {end "emit_body"}}
		}
		{anm "armor3"
			{forward {begin "board_MiddleArmor"} {end "pose_seat_sherman2_late_00"}}
			{reverse {end "emit_body"}}
		}
	}

	("seat_human" place(seat1) bone(seat01) door(emit3) animation(armor))
	("seat_human" place(seat2) bone(seat02) door(emit4) animation(armor1))
	("seat_human" place(seat3) bone(seat03) door(emit5) animation(armor2))
	("seat_human" place(seat4) bone(seat04) door(emit6) animation(armor3))

	{extender "inventory"
		{box
			{item "bulleteng_40 ap2" 99}				; 100 rounds
			{item "ammo mgun_eng belt" 2250}			; 12 belts (250 rounds each)
			{item "satchel_charge_eng" 1}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "40mm_qf2_2" filling "bulleteng_40 ap2" 1}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic"
				zeroing(2.5)
				dispersion(0.20)
			)
		}
		{place "mgun"
			{type "coaxial"}
			{weapon "vickers_tank" filled}
			{foresight "foresight5"}
			{gunner "gunner"}
			{charger "charger"}
			("abm_mgun")
			{basic}
		}
	}

	{mass 14377}
	{Chassis
		("tank_trace" fx("tracks_sm2") step(0.52) len(-0.95))
		("mobility_tank"
			speed(26) ;----------Max speed when fully accelerated on road, km/h.
			reverse(6) ;---------Max speed in reverse on road, km/h.
			traverse(30) ;-------Track traverse, per second, in degrees.
			weight(14.37) ;------Weight in Tonnes.
			power(150) ;---------Engine Power, in hp.
			track(7) ;-----------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(442) ;----------Fuel capacity in Litres.
			type(fuel) ;---------Fuel type. (diesel OR fuel)
			range(150) ;---------Range in km, off-road.
		)
	}

	{bone "gun_rot"
		{limits -15 20}
		{speed2 10}
	}

	{bone "turret"
		("turret_light" power_traverse(24)) ;// hydraulic
	}
}