{game_entity
	(include "/properties/car.ext")
	(include "/properties/selection/vehicle_elongated.inc" scale(1.10))
	{props "multi_board" "truck" "vision_lev02" "tractor" "tractor_medium" "Captor"}
	{able "emit_on_attack"}
	{extension "kfz70.mdl"}
	{collider "truck"}
	{patherId "blitz36"}

	{extender "enumerator"
		{digit_folder "np"}
	}

	("wheel" args "wheelright1")
	("wheel" args "wheelleft1")
	("wheel" args "wheelright2")
	("wheel" args "wheelright3")
	("wheel" args "wheelleft2")
	("wheel" args "wheelleft3")

	("glass" args "glass1")
	("glass" args "glass2")
	("fuel" args "fuel")
	("transmission" args "transmission")

	("bodyback" repair(30))

	("shield_cover")

	{volume "body2" {able {holed}}}
	{volume "bodyback1" {able {holed}}}
	{volume "bodyback2" {able {holed}}}
	{volume "shield_cover" {able {holed}}}

	("wood" args "bodyback1")
	("wood" args "bodyback2")
	("wood" args "bodyback3")
	("wood" args "bodyback4")

	("crew_2_human")

	("board_animation"
		place(driver)
		board_begin(board_SdKfz251-1)
		board_end(pose_kfz70_driver)
	)
	("board_animation"
		place(commander)
		board_begin(board_SdKfz251-1)
		board_end(pose_kfz70_commander)
	)

	{boarder
		{anm "passenger1"
			{forward {begin "board_body"} {end "pose_kfz70_passenger"} {base "board"}}
			{reverse {end "emit_body" 1} {base "board"}}
		}
		{anm "passenger2"
			{forward {begin "board_body"} {end "pose_kfz70_passenger2"}{base "board"}}
			{reverse {end "emit_body" 1}{base "board"}}
		}
		{anm "passenger3"
			{forward {begin "board_body"} {end "pose_kfz70_passenger3"}{base "board"}}
			{reverse {end "emit_body" 1}{base "board"}}
		}
		{anm "passenger4"
			{forward {begin "board_body"} {end "pose_kfz70_passenger4"}{base "board"}}
			{reverse {end "emit_body" 1}{base "board"}}
		}
	}
	("passenger_human" place(seat1)	bone(seat01)	door(emit3)	animation(passenger1) group(passenger))
	("passenger_human" place(seat2)	bone(seat02)	door(emit3)	animation(passenger4) group(passenger))
	("passenger_human" place(seat3)	bone(seat03)	door(emit3)	animation(passenger2) group(passenger))
	("passenger_human" place(seat4)	bone(seat04)	door(emit3)	animation(passenger1) group(passenger))
	("passenger_human" place(seat5)	bone(seat05)	door(emit3)	animation(passenger3) group(passenger))
	("passenger_human" place(seat6)	bone(seat06)	door(emit3)	animation(passenger3) group(passenger))
	("passenger_human" place(seat7)	bone(seat07)	door(emit3)	animation(passenger4) group(passenger))
	("passenger_human" place(seat8)	bone(seat08)	door(emit3)	animation(passenger2) group(passenger))

	{extender "shield" {on}}

	{extender "inventory"
		{box
		}
	}

	{mass 2600}
	{Chassis
		("car_trace" fx("tracewheel03") step(0.08) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("car_trace" fx("tracewheel03d") step(0.08) wheell("wlr") wheelr("wrr") bonel("FXtraceL2") boner("FXtraceR2"))
		("mobility_car"
			speed(70) ;----------------------------------Max speed.
			speedatmaxturn(15) ;-------------------------Max speed at max turn.
			reverse(22) ;--------------------------------Max speed in Reverse.
			weight(2.6) ;--------------------------------Weight in Tonnes.
			power(60) ;----------------------------------Horse Power.
			fuel(110) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;---------------------------------Fuel type.
			range(230) ;---------------------------------Range in Kilometers.
		)
	}
}

