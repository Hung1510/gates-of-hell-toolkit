{game_entity	;// normandy '44
	(include "/properties/tank_assaultgun.ext")
	(include "/properties/selection/vehicle_elongated.inc" scale(1.0))
	{props "td" "light" "-turret" "mantlet" "multi_board" "vision_lev03" "muzzle_75mm_76mm_sides" "shell_eject" "shield" "open_top" "detect_td_medium" "ammo_open_top"}
	{extension "geschutzwagen_39h.mdl"}
	(include "geschutzwagen_39h.ext")
	(include "crew.ext")
	{targetclass "tank_medium"}
	{targetSelector "tank_medium"}
	{patherId "panzer38"}
	{collider "tank.light"}

	{extender "shield" {on}}

	{extender "enumerator"
		{digit_folder "ger"}
	}

	{sensor
		{visor "around"
			{vision "vehicle_around"}		;// better vision than a in-closed turret 
		}
	}

	{extender "inventory"
		{box
			{item "bulletger_75_l43 apcbche" 11} 	; 38 rounds
			{item "bulletger_75_l43 he" 19}
			{item "bulletger_75_l43 apcr" 2}
			{item "bulletger_75_l43 heatc" 5}
			{item "geballteladung_3kg" 1}
		}
	}

	{Weaponry
		("restore_ik_time")
		{place "gun"
			{RestoreIKAfterAim}
			{weapon "75mm_pak40_2" filling "bulletger_75_l43 apcbche" 1}
			{gunner "gunner"}
			{charger "charger"}
			("abm_dymamic_td"
				zeroing(2.5)
				dispersion(0.25)
			)
			{rotate}
		}
	}

	{mass 13000}
	{Chassis
		("tank_trace" fx("tracks_sm2") step(0.2) len(0.55))
		("mobility_tank"
			speed(36) ;----------Max speed when fully accelerated on road, km/h.
			reverse(8) ;---------Max speed in reverse on road, km/h.
			traverse(30) ;-------Track traverse, per second, in degrees.
			weight(13.0) ;-------Weight in Tonnes.
			power(120) ;---------Engine Power, in hp.
			track(3.5) ;---------Track performance: (0,10], 10=ideal. Sluggish tanks and vehicles with narrow and non-gripping tracks have a lower performance.
			fuel(207) ;----------Fuel capacity in Litres.
			type(fuel) ;---------Fuel type. (diesel OR fuel)
			range(120) ;---------Range in km, off-road.
		)
	}

	{bone "gun_rot"
		{limits -5 22}
		{speed2 10}
	}
	{bone "turret"
		{limits -30 30}
		{speed2 8}
	}
}