{game_entity
	(include "/properties/vehicle_xx.ext")
	{extension "bf109_f4_xx.mdl"}

;// Main Airframe
	{volume "body1" {thickness 1}}
	{volume "body2" {thickness 1}}
	{volume "engine1" {thickness 1}}
	{volume "1blade1" {thickness 5}}
	{volume "1blade2" {thickness 5}}
	{volume "1blade3" {thickness 5}}
	{volume "stabilizer1" {thickness 1}}
	{volume "stabilizer2" {thickness 1}}
	{volume "rudder" {thickness 1}}
	{volume "elevator1" {thickness 1}}
	{volume "elevator2" {thickness 1}}
	{volume "wheelback" {thickness 0.5}}

;// Wing Right
	{volume "wingr1" {thickness 1}}
	{volume "wingr2" {thickness 1}}
	;{volume "flap2" {thickness 1}} // NOT PRESENT
	{volume "aileron2" {thickness 1}}
	{volume "gear_r" {thickness 1}}
	{volume "wheelr" {thickness 0.5}}

;// Wing Left
	{volume "wingl1" {thickness 1}}
	{volume "wingl2" {thickness 1}}
	;{volume "flap1" {thickness 1}} // NOT PRESENT
	{volume "aileron1" {thickness 1}}
	{volume "gear_l" {thickness 1}}
	{volume "wheell" {thickness 0.5}}
}
