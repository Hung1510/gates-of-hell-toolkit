{game_entity	;// normandy '44
	(include "/properties/armoredcar.ext")
	(include "/properties/selection/vehicle.inc" scale(1.0))
	{props "tank" "halftrack" "wheeled" "multi_board" "explosion_throw_crew" "vision_lev02" "tractor" "tractor_light" "detect_tank_mg" "open_death_fx_low"}
	{able "emit_passangers_on_enemy"}
	{extension "unic304f.mdl"}
	(include "unic304f.ext")
	{patherId "sdkfz251"}
	{targetclass "armoredcar"}
	{targetSelector "tank_bullet"}

	{extender "enumerator"
		{digit_folder "ger2"}
	}

	{boarder
		{anm "passenger1"
			{forward {begin "board_body"} {end "pose_seat_passenger_unic304f_01"} {base "board"}}
			{reverse {end "board_body" -1} {base "board"}}
		}
		{anm "passenger2"
			{forward {begin "board_body"} {end "pose_seat_passenger_unic304f_02"} {base "board"}}
			{reverse {end "board_body" -1} {base "board"}}
		}
		{anm "passenger3"
			{forward {begin "board_body"} {end "pose_seat_passenger_unic304f_03"} {base "board"}}
			{reverse {end "board_body" -1} {base "board"}}
		}
		{anm "passenger4"
			{forward {begin "board_body"} {end "pose_seat_passenger_unic304f_04"} {base "board"}}
			{reverse {end "board_body" -1} {base "board"}}
		}
		{anm "passenger5"
			{forward {begin "board_body"} {end "pose_seat_passenger_unic304f_05"} {base "board"}}
			{reverse {end "board_body" -1} {base "board"}}
		}
		{anm "passenger6"
			{forward {begin "board_body"} {end "pose_seat_passenger_unic304f_06"} {base "board"}}
			{reverse {end "board_body" -1} {base "board"}}
		}
		{anm "passenger7"
			{forward {begin "board_body"} {end "pose_seat_passenger_unic304f_07"} {base "board"}}
			{reverse {end "board_body" -1} {base "board"}}
		}
		{anm "driver"
			{forward {begin "board_body"} {end "pose_seat_driver_unic304f"} {base "board"}}
			{reverse {end "board_body" -1} {base "board"}}
		}
		{anm "gunner"
			{forward {begin "board_body"} {end "pose_mgun_251"} {base "board"}}
			{reverse {end "board_body" -1} {base "board"}}
		}
	}

	("crew" place(driver)		bone(driver)	door(emit1)		animation(driver)		visor(driver)	off({sensor}))
	("crew" place(gunner)		bone(gunner)	door(emit1)		animation(gunner)		visor(none)		off())

	("passenger" place(seat1) bone(seat1) door(emit1)  animation(passenger1)  off())
	("passenger" place(seat2) bone(seat2) door(emit1)  animation(passenger2)  off())
	("passenger" place(seat3) bone(seat3) door(emit1)  animation(passenger3)  off())
	("passenger" place(seat4) bone(seat4) door(emit1)  animation(passenger4)  off())
	("passenger" place(seat5) bone(seat5) door(emit1)  animation(passenger5)  off())
	("passenger" place(seat6) bone(seat6) door(emit1)  animation(passenger6)  off())
	("passenger" place(seat7) bone(seat7) door(emit1)  animation(passenger7)  off())

	{sensor
		{visor "human"
			{vision "none"}
		}
		{visor "around"
			{vision "none"}
		}
	}

	{extender "inventory"
		{weapon "mgun" {mask "mountable"}}
		{Box
			{item "mg42_belt_long" filling "ammo mgun_ger belt ap" 300 {user "mgun"}}
			{item "ammo mgun_ger belt ap" 2010}
		}
	}

	{Weaponry
		{place "mgun"
			{type "main"}
			{gunner "gunner"}
			{charger "gunner"}
			{LinkBone "mgun"}
			{LinkAnimation "off"}
			("abm_mgun")
			{ai_in_manual}
			{basic}
		}
	}

	{mass 5.5}
	{Chassis "wheel"
		("tank_trace_ex" fx("tracks_sm2") step(0.2) len(-0.49) boneleft("FXtraceL3") boneright("FXtraceR3"))
		("car_trace" fx("tracewheel03a") step(0.09) wheell("wlf") wheelr("wrf") bonel("FXtraceL1") boner("FXtraceR1"))
		("mobility_car"
			speed(40) ;----------------------------------Max speed.
			speedatmaxturn(14) ;-------------------------Max speed at max turn.
			reverse(9) ;---------------------------------Max speed in Reverse.
			weight(5.5) ;--------------------------------Weight in Tonnes.
			power(62) ;----------------------------------Horse Power.
			fuel(160) ;----------------------------------Fuel capacity in Litres.
			type(fuel) ;---------------------------------Fuel type.
			range(150) ;---------------------------------Range in Kilometers.
		)
	}
	{bone "mgun_a_rot1"
		{speed2 60}
	}
	{bone "mgun_a_rot2"
		{speed2 60}
	}

}