{game_entity
	(include "/properties/vehicle_xx.ext")
	{extension "sdkfz250a_11_xx.mdl"}

	{volume "body1"		; Lower Hull
		{thickness 8}
	}

	{volume "body2"		; Upper Hull
		{thickness 8}
		{able {holed}}
	}

	{volume "body3"		; Upper Hull
		{thickness 8
			{front 10}
		}
		{able {holed}}
	}

	{volume "engine1"	; Lower
		{thickness 8
			{front 14.5}
		}
	}

	{volume "engine2"	; Upper
		{thickness 8
			{front 14.5}
			{top 6}
		}
	}

	{volume "door_back"
		{thickness 8}
		{able {obstacle 0}}
	}

	{volume "gun1"
		{thickness 20}
	}

	{volume "gun2"
		{thickness 20}
	}

	{volume "gun3"
		{thickness 20}
	}

	{volume "gun4"
		{thickness 20}
	}

	{volume "part3"		; engine cover
		{thickness 8}
	}

	{volume "part4"
	}

	{volume "shield1"
		{thickness 8}
	}

	{volume "shield2"
		{thickness 8}
	}

	{volume "wheelleft1"
		{thickness 0.5}
	}
	{volume "wheelright1"
		{thickness 0.5}
	}

	("tracks" thickness(15))

	{volume "trackleft3"
		{able {obstacle 0}}
	}
}
